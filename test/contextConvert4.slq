// args: --run

def run(
	g_const: рЭЯЩ вЖТ рЭФє,
	g_moved: рЭЯЩ movedвЖТ рЭФє,
	g_onceвВА: рЭЯЩ onceвЖТ рЭФє,
	g_onceвВБ: рЭЯЩ onceвЖТ рЭФє,
	g_onceвВВ: рЭЯЩ onceвЖТ рЭФє,
){
	return (
		measure(g_const)(),
		measure(g_moved)(),
		measure(g_onceвВА)(),
		measure(g_onceвВБ)(),
		measure(g_onceвВВ)(),
	);
}


def main(){
	def f_classical()wildвЗТ0:рЭФє;
	x:=H(0);
	def f_const()wildвЗТdup(x);
	def f_moved()wildвЗТx;

	g_const := f_classical : рЭЯЩ вЖТ рЭФє;
	g_moved := f_classical : рЭЯЩ movedвЖТ рЭФє;
	g_onceвВА := f_classical : рЭЯЩ onceвЖТ рЭФє;
	g_onceвВБ := f_const : рЭЯЩ onceвЖТ рЭФє;
	g_onceвВВ := f_moved : рЭЯЩ onceвЖТ рЭФє;

	return run(g_const, g_moved, g_onceвВА, g_onceвВБ, g_onceвВВ);
}
