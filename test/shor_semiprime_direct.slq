
def main(){
	n:=21;
	k:=shor(n);
	assert(1<k&&k<n && n%k=0);
	return k;
}

def shor(N:!ℕ){
	while true{
		a:=2+uniform(N sub 2);
		d:=gcd(a,N);
		if d≠1{ return d; }
		n:=2·ceil(log₂(N))+1 coerce !ℕ;
		t:=[H(0) for i in 0..n] as uint[n];
		(s,x):=(1,a) pun !ℤstar[N]^2;
		for i in 0..n{
			if t[i]{ s·=x; }
			x·=x;
		}
		measure(s);
		for r in candidates((measure(reverse(QFT)(t)) as !ℕ)/2^n){
			k:=gcd(pow_mod(a,r div 2,N)+1,N);
			if 1<k∧k<N { return k; }
		}
	}
}

def candidates(q:!ℚ): !ℕ[] {
	r := [];
	(b, d) := (1, 0);
	while q!=0 {
		q = 1/q;
		k := floor(q) coerce !ℕ;
		(b, d) = (k*b+d, b);
		if b>1 { r ~= [b]; }
		q -= k;
	}
	return r;
}

def QFT[n:!ℕ](ψ: uint[n])mfree: uint[n]{
	for k in [0..n div 2){
		(ψ[k],ψ[n-k-1]) := (ψ[n-k-1],ψ[k]);
	}
	for k in [0..n){
		ψ[k] := H(ψ[k]);
		for l in [k+1..n){
			if ψ[l] && ψ[k]{
				phase(2·π · 2^(k-l-1));
			}
		}
	}
	return ψ;
}

def uniform(n:!ℕ){
	while true {
		k:=ceil(log₂(n));
		x:=[measure(H(0)) for _ in 0..k] as !uint[_] as !ℕ;
		if x<n{ return x; }
	}
}
