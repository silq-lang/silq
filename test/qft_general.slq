// args: --project-forget
import uniformSuperposition;

t:=2; // (increase for higher fidelity)
def estimate[N:!ℕ](ys:ℤmod[N]){
	xs:=0:!uint[t·n[N]];
	for i in 0..t·n[N]{
		bit:=H(0);
		if bit{
			ys-=2^(t·n[N]-i sub 1);
			for j in 0..i+1{
				if xs[j]{ phase(-2·π·2^(j-i-1)); }
			}
		}
		(xs[i],0):=(H(bit),xs[i]);
	}
	return (xs,ys);
}

def pad[n:!ℕ][a:*,m:!ℕ](xs:a^m,x:!a)=>xs~vector(n sub m,x);

def QFT[N:!ℕ](xs:ℤmod[N]){
	ys:=uniformSuperposition(N) as 𝔹^_ coerce 𝔹^n[N] as  uint[n[N]] pun ℤmod[N];
	for i in 0..n[N]{
		for j in 0..n[N]{
			if (xs pun uint[n[N]])[i]&&(ys pun uint[n[N]])[j]{
				phase(2·π·2^(i+j)/N);
			}
		}
	}
	with{
		(nxs,ys):=estimate[N](ys);
		nxs:=pad[(t+1)·n[N]](nxs as 𝔹^_,0) as uint[_];
	}do{
		forget((xs pun uint[n[N]])=((N·nxs+2^(t·n[N] sub 1)) as 𝔹^_)[t·n[N]..(t+1)·n[N]] as uint[n[N]]);
	}
	return ys;
}

def main()⇒QFT[13](2:ℤmod[13]);
