// args: --run

def unbalancedW[n:!ℕ](α:!ℂ^n):𝔹^n{
	def build[i:!ℕ,l:!ℕ,u:!ℕ](t:!ℝ^(4·n)){
		if l+1=u{
			t[i]=cabs(α[l])^2;
		}else{
			m:=(l+u) div 2;
			t:=build[2·i+1,l,m](build[2·i+2,m,u](t));
			t[i]=t[2·i+1]+t[2·i+2];
		}
		return t;
	}
	t:=build[0,0,n](vector(4·n,0));
	def rec[i:!ℕ][l:!ℕ,u:!ℕ](xs:𝔹^(u sub l)){
		if l+1=u{ return xs; }
		m:=(l+u) div 2;
		(α₀,α₁):=t[2·i+1..2·i+3];
		if α₀+α₁=0{ return xs; }
		θ:=2·acos(sqrt(α₀/(α₀+α₁)));
		([a]~xs₀:_^(m sub l))~([b]~xs₁):=xs;
		with b⊕=a { if b{ a:=rotY(-θ,a); } }
		(xs₀,xs₁):=(rec[2·i+1][l,m]([a]~xs₀),rec[2·i+2][m,u]([b]~xs₁));
		return xs₀~xs₁;
	}
	xs:=rec[0][0,n]([1]~vector(n sub 1,0));
	for i in 0..n{ if xs[i]{ phase(carg(α[i])); } }
	return xs;
}

def main() ⇒ unbalancedW([sqrt(1/2),-sqrt(1/4),sqrt(1/4)*cis(1)]);
