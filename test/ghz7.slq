
def ghz(n:!ℕ){ // (not particularly useful)
	xs:=[H(0) for i in 0..n];
	def rec[l:!ℕ,u:!ℕ](t:(!ℕ^2)[]){
		if u-l=1{ return t; }
		m:=(l+u) div 2;
		return [(l,m)]~rec[l,m](rec[m,u](t));
	}
	t:=rec[0,n]() coerce _^(n sub 1);
	bs:=measure([xs[a]⊕xs[b] for (a,b) in t]);
	p:=vector(n,0);
	for (i,(a,b)) in enumerate(t){
		p[b]=p[a]⊕bs[i];
		xs[b]⊕=p[b];
	}
	return xs;
}
def main() ⇒ ghz(8);

def zip[a:*,b:*,n:!ℕ](xs:a^n,ys:b^n){
	r:=[];
	for i in 0..n{
		[x]~xs:=xs;
		[y]~ys:=ys;
		r~=[(x,y)];
	}
	([],[]):=(xs,ys);
	return r coerce _^n;
}

def enumerate[a:*,n:!ℕ](xs:a^n) => zip([i for i in 0..n],xs);
