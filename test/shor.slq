
def main(){
	n:=21;
	k:=shor(n);
	assert(1<k&&k<n && n%k=0);
	return k;
}

def shor(n:!ℕ){
	if n%2=0 { return 2; }
	(x,y):=asPower(n);
	if y>1{ return x; }
	while true{
		a:=2+uniform(n sub 2);
		d:=gcd(a,n);
		if d≠1{ return d; }
		a:=a coerce !ℤstar[n];
		r:=order(a);
		k:=gcd(a^(r div 2)+1 as !ℕ,n);
		if 1<k∧k<n { return k; }
	}
}

def asPower(n:!ℕ){
	y:=2;
	while 3^y≤n{
		(l,r):=(0,1);
		while r^y≤n{ r*=2; }
		while l+1≠r{
			m:=(l+r) div 2;
			if m^y≤n { l=m; }
			else { r=m; }
		}
		if l^y=n{ return (l,y); }
		y+=1;
	}
	return (n,1);
}

// order-finding:
def order[N:!ℕ](a:!ℤstar[N]){
	n:=2·ceil(log₂(N))+1 coerce !ℕ;
	while true{
		def f(b:uint[n])lifted ⇒ a^b;
		for r in candidates(estimate_phase[n](f)/2^n){
			if r≠0 && a^r=1{
				return r;
			}
		}
	}
}

def estimate_phase[n:!ℕ][a:*](f:uint[n] !→lifted a):!ℕ{
	cand := [H(0) for i in 0..n] as uint[n];
	measure(f(cand));
	cand := reverse(QFT)(cand);
	return measure(cand) as !ℕ;
}

def candidates(q:!ℚ): !ℕ[] {
	r := [];
	(b, d) := (1, 0);
	while q!=0 {
		q = 1/q;
		k := floor(q) coerce !ℕ;
		(b, d) = (k*b+d, b);
		if b>1 { r ~= [b]; }
		q -= k;
	}
	return r;
}

def QFT[n:!ℕ](ψ: uint[n])mfree: uint[n]{
	for k in [0..n div 2){
		(ψ[k],ψ[n-k-1]) := (ψ[n-k-1],ψ[k]);
	}
	for k in [0..n){
		ψ[k] := H(ψ[k]);
		for l in [k+1..n){
			if ψ[l] && ψ[k]{
				phase(2·π · 2^(k-l-1));
			}
		}
	}
	return ψ;
}

def uniform(n:!ℕ){
	while true {
		k:=ceil(log₂(n));
		x:=[measure(H(0)) for _ in 0..k] as !uint[_] as !ℕ;
		if x<n{ return x; }
	}
}
