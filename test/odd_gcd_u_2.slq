// args: --run

def odd_gcd_u[n:!ℕ](x:uint[n],y:uint[n])lifted{
	def rec(i:!ℕ, const a:uint[n], const b:uint[n]){
		if i+1 == n{ return b; }
		(a', b') := if b < a then (b, a) else (a, b);
		if a[0]==b[0]{ (a'', b'') := ((b' - a') div 2, a'); }
		else { (a'', b'') := (a,b); }
		if !a''[0]{ a'' div=2; }
		return rec(i+1,a'',b'');
	}
	return rec(0,x,y);
}

def main(){
	x:=[1]~[H(0) for i in 0..2] as uint[_];
	y:=[1]~[H(0) for i in 0..2] as uint[_];
	r:=odd_gcd_u(x,y);
	return (x,y,r);
}
