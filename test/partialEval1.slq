// args: --run

def f[n:!ℕ](const x:uint[2·n]){
	x₀:=0:uint[n sub 2];
	x₁:=x₀:uint[-2+n coerce !ℕ];
	x₂:=x:uint[3·n sub n];
	x₃:=x:uint[n·2];
	x₄:=x:uint[n+n];
	x₅:=x:uint[2·n+1 sub 1];
	x₆:=x:uint[2·(n sub 1)+2];
	x₇:=x:uint[4·n sub (n+n)];
	x₈:=x:uint[4·n sub (n+n)+(n sub (n sub 1)) sub 1];
	y:=0:uint[n·3];
	y₀:=dup(y):uint[n·2+n];
	y₁:=dup(y):uint[n+2·n];
	y₂:=dup(y):uint[n+n·2];
	y₃:=dup(y):uint[n+n+n];
    return x;
}

def main() {
    measure(f[2](1:uint[4]));
	x:=0:uint[4];
	y:=x:uint[6 sub 2];
}
