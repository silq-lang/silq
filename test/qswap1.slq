
def qswap[n:!ℕ,qt:qtype,ilen:!ℕ](const idx:uint[ilen],arr:qt^n,val:qt){
	def rec(k:!ℕ,cidx:!uint[ilen],arr:qt^n,val:qt){
		if k == ilen{
			(arr[cidx],val):=(val,arr[cidx]);
			return (arr,val);
		} else if idx[k] {
			cidx[k] = 1;
			if cidx>=n {
				__qabort(qt^n×qt) := (arr,val);
				return __qabort(qt^n×qt);
			} else {
				return rec(k+1,cidx,arr,val);
			}
		} else {
			return rec(k+1,cidx,arr,val);
		}
	}
	return rec(0,0:!uint[ilen],arr,val);
}

def main(){
	r:=qswap(1:!uint[2],(0,0),1);
	assert(r=((0,1),0));
	return r;
}
