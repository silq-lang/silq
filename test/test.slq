def main(){
	n:=10;
	y:=measure(H(0:𝔹),H(0:𝔹),H(0:𝔹),H(0:𝔹),H(0:𝔹),H(0:𝔹),H(0:𝔹),H(0:𝔹),H(0:𝔹),H(0:𝔹));
	x:=vector(10,0:𝔹);
	for i in [0..n){ x[i]:=H(x[i]); }
	r := 0:𝔹;
	for i in [0..n){ r⊕=x[i]&y[i]; }
	if r { phase(π); }
	forget(r);
	for i in [0..n){ x[i]:=H(x[i]); }
	assert(measure(x)==y);
}
