def main(){
	x:=H(0:𝔹);
	z:=H(0:𝔹);
	fy₁:=lambda(const z:𝔹)lifted⇒dup(z);
	fy₂:=lambda(const z:𝔹)lifted⇒!z;
	fy₃:=lambda(const x:𝔹,const z:𝔹)lifted⇒if x then fy₁(z) else fy₂(z);
	if x{
		y:=dup(z);
	}else{
		y:=!z;
	}
	//y:=if x then dup(z) else !z;
	forget(y=fy₃(x,z));
	return (x,z);
}
