	x:=vector(n,0:𝔹);
	for i in [0..n){ x[i] := H(x[i]); }
	if f(x){ phase(π); }
	for i in [0..n){ x[i] := H(x[i]); }
	return measure(x)==vector(n,0:!𝔹);
}
