def rQFT[n:!ℕ](ψ: int[n])mfree{
    for k in (n..-1..0]{
        for l in (n..-1..k + 1]{
            if ψ[k] && ψ[l] {
                reverse(phase)(2 · π · 2 ^ (k - l - 1),());
            }
        }
        __tmp2 := ψ[k];
        __tmp2 := reverse(H)(__tmp2);
        ψ[k] := __tmp2;
    }
    for k in (n div 2..-1..0]{
        __tmp1 := ψ[n - k - 1];
        __tmp0 := ψ[k];
        (__tmp1,__tmp0) := (__tmp0,__tmp1)^2;
        ψ[n - k - 1] := __tmp1;
        ψ[k] := __tmp0;
    }
    return ψ coerce int[n];
}

def main(){
	return rQFT(0:int[2]);
}
