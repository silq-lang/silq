def H_n[n:!ℕ](xs:𝔹^n)mfree: 𝔹^n {
	if n≠0 {
		with (h,)~t:=xs do {
			h := H(h);
			t := H_n(t);
		}
	}
	return xs;
}

def maj(x:𝔹,y:𝔹,z:𝔹)lifted => if x=y then y else z;

def dj(){
	xs := (0,0,0): 𝔹^3;
	with xs := H_n(xs) do {
		if maj(xs) {
			phase(π);
		}
	}
	return measure(xs)≠(0,0,0);
}

def main(){
	return dj();
}
