def makeTeleporter(){
	shared₀:=H(0:𝔹);
	shared₁:=dup(shared₀);
	def send(message:𝔹){
		shared₀:=shared₀;
		shared₀⊕=message;
		return measure(H(message),shared₀);
	}
	def receive(p:!𝔹,f:!𝔹){
		shared₁:=shared₁;
		if p && shared₁ { phase(π); }
		if f { shared₁:=X(shared₁); }
		return shared₁;
	}
	return (send,receive);
}

def main(){
	(send,receive):=makeTeleporter();
	//return (send,receive);
	x:=send(H(1:𝔹));
	return receive(x);
}
