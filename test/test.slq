def solve[n:!ℕ](f: 𝔹^n !→lifted 𝔹){
	x:=0:int[n];
	for i in [0..n){ x[i] := H(x[i]); }
	if f(x as 𝔹^n){ phase(π); }
	for i in [0..n){ x[i] := H(x[i]); }
	return measure(x)==0;
}
//import codeforces.summer18.warmup.i;
def main(){
	f := λ[n:!ℕ](x: 𝔹^n)lifted{
		r:=0:𝔹;
		for i in [0..n){
			r⊕=x[i];
		}
		return r;
	};
	g := λ[n:!ℕ](x: 𝔹^n)lifted⇒0:𝔹;
	x:=solve(f[1]);
	y:=solve(g[1]);
	return (x,y);
}
