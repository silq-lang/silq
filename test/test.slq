/+
def cmp(const __tmp2: 𝔹^2,const __tmp3: !𝔹^2)qfree{
    __tmp4 := 0;
    __tmp5 := 0;
    if ¬__tmp4 {
        if 2 ≠ 2 {
            __tmp4 ← 1;
            __tmp5 ← 0;
        }
    }
    if ¬__tmp4 {
        for __tmp6 in [0..2){
            if ¬__tmp4 {
                if __tmp2[__tmp6] ≠ __tmp3[__tmp6] {
                    __tmp4 ← 1;
                    __tmp5 ← 0;
                }
            }
        }
    }
    if ¬__tmp4 {
        __tmp4 ← 1;
        __tmp5 ← 1;
    }
    return dup(__tmp5);
}+/

