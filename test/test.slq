// expand3.slq
def expand[n: !ℕ](x: uint[n]) qfree: uint[2*n] {
    v₀ := 0 as uint[n];
    return ((x as 𝔹^n) ~ (dup(v₀) as 𝔹^n)) as uint[2*n];
}


def main() {
    a := 1: uint[1];
    q := H(0: 𝔹);
    if q {
        expand[1](a) := expand[1](a);
    }
    q := H(q);
    measure(q);
    return a;
}
