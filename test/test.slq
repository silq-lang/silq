def egcd(a:!ℤ,b:!ℤ){
	(x,y,u,v):=(a,b,1,0):!ℤ^4;
	while y≠0{
		(x,y,u,v)=
			(y,x%y,v,u-(x div y)·v);
	}
	return (x,u);
}
