def foo(a:𝔹[]×(!𝔹[]×𝔹),b:𝔹[]×(!𝔹[]×𝔹))lifted{
	done:=0;
	r:=0;
	if !done {
		for i in 0..if a[0].length<b[0].length then a[0].length else b[0].length{
			if !done {
				if a[0][i]≠b[0][i]{
					done=true;
					r=a[0][i]<b[0][i];
				}
			}
		}
		if !done{
			if a[0].length≠b[0].length{
				done=true;
				r=a[0].length<b[0].length;
			}
		}
	}
	return r;
}
