def zip[σ:*,τ:*,n:!ℕ](xs: σ^n, ys: τ^n)mfree: (σ×τ)^n {
	if n=0 {
		():=xs coerce σ^0;
		():=ys coerce τ^0;
		r:=() coerce (σ×τ)^n;
	} else {
		xs~(x,) := xs;
		ys~(y,) := ys;
		r := zip(xs,ys)~((x,y),);
	}
	return r;
	/*xs:=xs:σ[];
	ys:=ys:τ[];
	r:=[]:(σ×τ)[];
	for i in 0..n{
