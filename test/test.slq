def program(f:𝔹!→mfree 𝔹){
    x:=0:𝔹;
    y:=f(dup(x));
    if y{
        x:=H(x);
    }
	dump();
    y:=reverse(f)(y);
	assert(measure(y=x));
	forget(y=x);
    dump();
    measure(x);
}

