def add[n:!ℕ](a:uint[n],b:uint[n])lifted{
	c:=0:uint[n];
	carry:=0:𝔹;
	for i in [0..n){
		c[i]=a[i]⊕b[i]⊕carry;
		carry=a[i]&b[i]|a[i]&carry|b[i]&carry;
	}
	return c;
}

def main(){
	a:=13:uint[32];
	b:=24:uint[32];
	a[0]:=H(a[0]);
	b[1]:=H(b[1]);
	return (add(a,b),a,b);
}
