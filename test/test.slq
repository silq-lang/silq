def assign[a:*,b:*](forgettable[y] x:a,y:b){
	forget(x);
	return y;
}

def inPlaceAdd[a:*,b:*,Add[a,b]](x:a,y:b){
	x+=y;
	return x;
}

def main(){
	// ...
	x:=assign(x,y); // x=y
	x:=inPlaceAdd(x,y); //x+=y
}
