def good(x:uint[8]){
	xt~(xh,):=x as 𝔹^8;
	x:=(xh,)~xt as uint[8];
	return x;
}

def bad(x:uint[8]){
	tmp:=dup(x);
	tmp+=x;
	(x,tmp):=(tmp,x);
	tt~(th,):=tmp as 𝔹^8;
	tmp:=(th,)~tt as uint[8];
	tmp-=x;
	forget(tmp=0);
	return x;
}

def main(){
	//return good(129:uint[8]);
	return bad(127:uint[8]);
}
