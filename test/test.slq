def a4_HADAMARD_Array[k:!N](q:𝔹^k) : 𝔹^k {
	for j in [0..k) { q[j] := H(q[j]); }
	return q;
}

def a7_Diffuse_Array[k:!N](q:𝔹^k) : 𝔹^k {
	q := a4_HADAMARD_Array(q);
	if q == array(k,false) { phase(π); }
	q := a4_HADAMARD_Array(q);
	return q;
}
