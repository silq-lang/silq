def walk[n:!ℕ](qs:𝔹^n,m:!ℕ,const f:𝔹^n → mfree 𝔹^n) mfree{
    z := 0:𝔹;
    for i in [0..m){
        z |= qs[i]==0;
    }
    if z{phase(π);}
    forget(z);
    qs := reverse(f)(qs);
    //f(qs) := qs;
    z := 0:𝔹;
    for i in [0..m){
        z |= qs[i]==0;
    }
    if z=0{phase(π);}
    forget(z);
    qs := f(qs);
    return qs;
}
def amplitude_amplification[n:!ℕ](qs:𝔹^n,m:!ℕ,const f:𝔹^n → mfree 𝔹^n){
    nIterations:=floor(π/(4·asin(2^(-n/2)))-1);
    for k in [0..nIterations){
        qs := walk(qs,m,f);
    }
    return qs;
}
def cnot(const x:𝔹,y:𝔹):𝔹{
  if x{
    y := X(y);
  }
  return y;
}
def gate(qs:𝔹^3) mfree{
    qs[0] := rotY(π/3,qs[0]);
    qs[2] := rotY(π/3,qs[2]);
    qs[1] := cnot(qs[0],qs[1]);
    qs[0] := X(qs[0]);
    qs[2] := cnot(qs[1],qs[2]);
    return qs;
}
def main(){
    qs := 0:uint[3] as 𝔹^3;
    m := 1:!ℕ;
    qs := gate(qs);
    qs := amplitude_amplification(qs,m,gate);
    return qs;
}
