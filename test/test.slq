def estimatePhase[n:!ℕ][a:qtype](const f: Pi[nrep: !ℕ]qfree. a ->mfree a, arg: a)mfree: uint[n] x a{
	x_tilde := 0: uint[n];
	for i in 0..n {
		bit := H(0);
		if bit {
	        nrep := 2^(n sub 1 sub i);
			arg := f[nrep](arg);
			phaseU(nrep * -x_tilde);
		}
		(x_tilde[i], 0) := (H(bit), x_tilde[i]);
	}
	return (x_tilde, arg);
}

def phaseU[n: !N](const x: uint[n]) {
	for i in 0..n {
		if x[i] {
			phase(2*pi * 2^i/2^n);
		}
	}
}

n := 3;
def main() {
	def f[nrep:!N](x: uint[n]){
		x += nrep;
		return x;
	}
	x := 0 as uint[n];
	(x_tilde, x) := estimatePhase[n](f, x);
	return (x_tilde, x);
}
