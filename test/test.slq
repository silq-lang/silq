def rfoo(__tmp12:𝔹)mfree{
    def bar(moved i: ¬ℕ,moved x: 𝔹)mfree:𝔹{
        if i = 0 {
            r := x;
        } else {
            r := bar(i sub 1,X(x));
        }
        return r;
    }
    bar(10,x) := __tmp12;
    return x coerce 𝔹;
}

