	}
	__show(__query("type",xs));
	():=xs;
	():=ys;
	return r coerce (σ×τ)^n;*/
}

def unzip[τ:*,n:!ℕ](x: (τ^2)^n){
	zip(x,y):=x;
	return (x,y);
}

def map[σ:*,τ:*](f: σ !→mfree τ)[n:!ℕ](xs: σ^n)mfree: τ^n{
	ys := []:τ[];
	xs := xs:σ[];
	for i in 0..n{
		(x,)~xs := xs;
		ys~=[f(x)];
	}
	//__show(__query("dep",xs));
	():=xs;
	return ys coerce τ^n;
	/+if n=0{
		():=xs coerce σ^0;
		r:=() coerce τ^n;
	}else{
		(x,)~xs := xs;
		r:=(f(x),)~map(f)(xs);
	}
	return r;+/
}

