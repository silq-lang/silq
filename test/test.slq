def fib(f: !ℕ !→ !ℕ)(n:!ℕ){
	if n<=1{ return n; }
	return f(n sub 1)+f(n sub 2);
}

def fix[a](f: (a!→a)!→(a!→a)){
	def g(x:a):a⇒f(g)(x); // TODO
	return g;
}
def main(){
	return fix(fib)(10);
}
