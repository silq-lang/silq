def intLt₃[n:!ℕ](x:𝔹^n,y:𝔹^n)lifted:𝔹{
    if n=0{ return false; }
	r := intLt₃(x[0..n sub 1],y[0..n sub 1]);
	res := if x[n-1]=y[n-1] then dup(r) else y[n-1];
	intLt₃(assert(0),assert(0)):=r; // TODO: better error message
	return res;
}
