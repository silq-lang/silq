def map(a:type,b:type)[f:a→b][n:!ℕ](xs:a^n){
	ys:=();
	//for x in xs{ ys~=f(x); } // TODO
	for i in 0..n{
		[x]~xs:=xs;
		ys~=[f(x)];
	}
	():=xs;
	// return ys; // TODO: ys: b^n
	return ys coerce b^n;
}

