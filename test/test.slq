def f(a: 𝔹){
	x:=!a; // x ↦ {a}
	y:=!x; // x ↦ {a}, y ↦ {x}
	if y {
		xp := dup(x); // xp ↦ {x}, x ↦ {a}, y ↦ {x}
		__show(__query("dep",xp));
		xp := H(xp);
		// y ↦ {x}, x ↦ {a}
	} else {
		xp := dup(x); // x=xp, y ↦ {x}, x ↦ {a}
		// x↦{xp}, y ↦ {x}, xp ↦ {a}
		a := H(a);
		// x ↦ {xp}, y ↦ {x}, xp ↦ {a}
	}
	// x ↦ {xp}, y → {xp}
	(x,xp) := (xp,x); // x → ⊤,
	// x ↦ {y, a, ap}, y ↦ {cond, x, xp}
	__show(__query("dep",y));
	forget(xp);
	return (x,a,y);
}
