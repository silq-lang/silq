def splitFront[m:!ℕ][a:type,n:!ℕ](xs:a^n)qfree:a^m×a^(n sub m){
	(anc:a^m)~(xs:a^(n sub m)):=xs;
	return (anc,xs);
}
def dropAncillas[m:!ℕ][n:!ℕ](xs:𝔹^n):!𝔹×𝔹^(n sub m){
	(anc,xs):=splitFront[m](xs);
	success:=(measure(anc) as !uint[m]) = 0;
	return (success,xs);
}
def main(){
	return dropAncillas[2]([H(0)]~vector(4,0));
}
