n:=3;

// generate uniform superposition of |0⟩,…,|N-1⟩
def uniformSuperposition[n:!ℕ](N:!ℕ){
	while true {
		x:=0:uint[n];
		for i in 0..n{ for j in 0..n { x[i]:=H(x[i]); } }
		if measure(x<N){ return x; }
		measure(x);
	}
}
