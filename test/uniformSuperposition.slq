// according to: https://quantumcomputing.stackexchange.com/a/11740

def H_n[n:!ℕ](xs:𝔹^n){
	for i in 0..n{ xs[i]:=H(xs[i]); }
	return xs;
}

def n[N:!ℕ]⇒ceil(log₂(N)) coerce !ℕ;

def uniformSuperposition(N:!ℕ)mfree{
	(k,L):=(0,N);
	while (L&1)=0 { L div=2; k+=1; }
	(t,logL):=(1,0);
	while t<L { t·=2; logL+=1; }
	a:=H_n(vector(logL,0));
	φ:=acos(1-2^(logL-1)/L);
	if (a as uint[logL])<L { phase(φ); }
	with a:=H_n(a) do if (a as uint[logL])=0{ phase(φ); }
	phase(-(φ+π)/2);
	return H_n(vector(k,0))~a coerce 𝔹^n[N] as uint[_];
}

def main()⇒uniformSuperposition(3);
