// GQSP (laneve)
// https://arxiv.org/pdf/2503.03026

def fft[N:!в„•](xs:!в„‚^N):!в„‚^N {
	if N=1 { return xs; }
	assert(N%2=0);
	xs_e:=vector(N div 2,0);
	xs_o:=vector(N div 2,0);
	for j in 0..N div 2{
		xs_e[j]=xs[2В·j];
		xs_o[j]=xs[2В·j+1];
	}
	ys_e:=fft(xs_e);
	ys_o:=fft(xs_o);
	ys:=vector(N,0);
	for k in 0..N div 2{
		t:=cis(-2В·ПЂВ·k/N)В·ys_o[k];
		ys[k]=ys_e[k]+t;
		ys[k+N div 2]=ys_e[k]-t;
	}
	return ys;
}
def ifft[N:!в„•](ys:!в„‚^N):!в„‚^N {
	for i in 0..N{ ys[i]:=conj(ys[i]); }
	xs:=fft(ys);
	for i in 0..N{ xs[i]:=conj(xs[i])/N; }
	return xs;
}

def poly_eval[d:!в„•](coeffs:!в„‚^(d+1))(x:!в„‚):!в„‚{
	r:=coeffs[d];
	for i in (d..-1..0]{
		r=rВ·x+coeffs[i];
	}
	return r;
}

def pad[m:!в„•][a:type,n:!в„•](xs:a^n,const x:a):a^mв‡’xs~vector(m sub n,x);

// berntson-sГјnderhauf
// https://arxiv.org/abs/2406.04246
def thm3_Nв‚Ђ(Оµ:!в„ќ,Оґ:!в„ќ,d:!в„•):!в„•{
	assert(0<Оґв€§Оґ<1в€§0<Оµв€§Оµ<1);
	rОґ:=(1/(1-Оґ))^(1/d);
	Nв‚Ђ:=ceil(2/log(rОґ)В·log(8В·-log(Оґ)/(rОґ-1)/Оµ)) coerce !в„•;
	return ceil(Nв‚Ђ) coerce !в„•;
}
def heuristic_Nв‚Ђ(Оµ:!в„ќ,Оґ:!в„ќ,d:!в„•):!в„•{
	rОґm1:=expm1(-log1p(-Оґ)/d);
	Nв‚Ђ:=ceil(2В·d/-log1p(-Оґ)В·log(8В·-log(Оґ)/(ОµВ·rОґm1))) coerce !в„•;
	return ceil(Nв‚ЂВ·Оґ) coerce !в„•; // seems good enough?
}
def complement_alg1[d:!в„•](p:!в„‚^(d+1),N:!в„•):!в„‚^(d+1){
	ps:=fft(pad[N](p,0));
	в„“:=vector(N,0);
	for j in 0..N { в„“[j]=log(1-cabs(ps[j])^2); }
	в„“:=ifft(в„“);
	log_qs:=fft(pad[N]([в„“[0]/2]~в„“[1..N div 2+1],0));
	qs:=vector(N,0);
	for j in 0..N { qs[j]=cexp(log_qs[j]); }
	return ifft(qs)[0..d+1];
}

def complement_alg2[d:!в„•](p:!в„‚^(d+1),Оµ:!в„ќ,N:!в„•):!в„‚^(d+1){
	for i in 0..d+1{ p[i]В·=1-Оµ/4; }
	return complement_alg1[d](p,N);
}

def complement[d:!в„•](p:!в„‚^(d+1),Оµ:!в„ќ):!в„‚^(d+1){
	//Nв‚Ђ:=thm3_Nв‚Ђ(Оµ/4,Оµ/(5В·(d+1)),d);
	Nв‚Ђ:=heuristic_Nв‚Ђ(Оµ/4,Оµ/(5В·(d+1)),d);
	N:=2^(ceil(logв‚‚(max(Nв‚Ђ,d+1))) coerce !в„•);
	return complement_alg2[d](p,Оµ,N);
}

def is_complement[N:!в„•][d:!в„•](p:!в„‚^(d+1),q:!в„‚^(d+1),Оµ:!в„ќ){
	assert(Nв‰Ґd+1в€§(N&(N-1))=0);
	ps:=fft(pad[N](p,0));
	qs:=fft(pad[N](q,0));
	ok:=1;
	for j in 0..N{
		ok&=abs(cabs(ps[j])^2+cabs(qs[j])^2-1)<Оµ;
	}
	return ok;
}

// ni-sarkar-ying-lin
// https://arxiv.org/pdf/2505.12615
def vadd[n:!в„•](a:!в„‚^n,b:!в„‚^n):!в„‚^n{
	r:=vector(n,0);
	for i in 0..n { r[i]=a[i]+b[i]; }
	return r;
}
def vsub[n:!в„•](a:!в„‚^n,b:!в„‚^n):!в„‚^n{
	r:=vector(n,0);
	for i in 0..n { r[i]=a[i]-b[i]; }
	return r;
}
def vscale[n:!в„•](c:!в„‚,a:!в„‚^n):!в„‚^n{
	r:=vector(n,0);
	for i in 0..n { r[i]=cВ·a[i]; }
	return r;
}
def rev[n:!в„•](a:!в„‚^n):!в„‚^n{
	r:=vector(n,0);
	for i in 0..n { r[i]=a[n-1-i]; }
	return r;
}
def sharp[n:!в„•](a:!в„‚^n):!в„‚^n{
	r:=vector(n,0);
	for i in 0..n { r[i]=conj(a[n-1-i]); }
	return r;
}

// returns coefficients of a*b (polynomial convolution).
def conv[n:!в„•](a:!в„‚^n,b:!в„‚^n):!в„‚^(2В·n sub 1){
	if n=1 { return [a[0]В·b[0]] coerce !в„‚^(2В·n sub 1); }
	Af:=fft[2В·n](pad[2В·n](a,0));
	Bf:=fft[2В·n](pad[2В·n](b,0));
	Cf:=vector(2В·n,0);
	for i in 0..2В·n { Cf[i]=Af[i]В·Bf[i]; }
	return ifft[2В·n](Cf)[0..2В·n sub 1];
}

def inlfft[n:!в„•](a0s:!в„‚^n,b0:!в„‚^n):(!в„‚^n)^3{ // (alg. 1)
	assert(nв‰Ґ1в€§(n&(n-1))=0);
	// step 1: base case
	if n=1 {
		Оі0:=b0[0]/a0s[0];
		О·0:=1/sqrt(1+cabs(Оі0)^2);
		Оѕ0:=Оі0В·О·0;
		return ([Оі0],[Оѕ0],[О·0]) coerce (!в„‚^n)^3;
	}
	m:=n div 2;
	// step 2: recurse on first m coefficients of a_0^*, b_0
	(Оі_up,Оѕm,О·m):=inlfft[m](a0s[0..m],b0[0..m]);
	// step 3 (eq. 39): form am^*,bm
	О·m_sh:=pad[n]([0]~sharp[m](О·m),0);
	Оѕm_sh:=pad[n]([0]~sharp[m](Оѕm),0);
	О·m_n:=pad[n](О·m,0);
	Оѕm_n:=pad[n](Оѕm,0);
	// am^* = (О·m^в™ЇВ·a0^* + Оѕm^в™ЇВ·b0)/z^m
	ams:=vadd[m](conv[n](О·m_sh,a0s)[n-m..n],conv[n](Оѕm_sh,b0)[n-m..n]);
	// bm = (-ОѕmВ·a0^* + О·mВ·b0)/z^m
	bm:=vadd[m](vscale[m](-1,conv[n](Оѕm_n,a0s)[n-m..n]),conv[n](О·m_n,b0)[n-m..n]);
	// step 4: recurse on second m coefficients of a_m^*,b_m
	(Оі_dn,Оѕr,О·r):=inlfft[m](ams,bm);
	Оі:=Оі_up~Оі_dn coerce _^n;
	// step 5 (eq. 40): calculate Оѕn and О·n
	О·r_sh:=pad[n]([0]~sharp[m](О·r),0);
	Оѕr_sh:=pad[n]([0]~sharp[m](Оѕr),0);
	О·r_n:=pad[n](О·r,0);
	Оѕr_n:=pad[n](Оѕr,0);
	// Оѕn = О·m^sharp * Оѕr + Оѕm * О·r
	Оѕn:=vadd[n](conv[n](О·m_sh,Оѕr_n)[0..n],conv[n](Оѕm_n,О·r_n)[0..n]);
	// О·n = -Оѕm^sharp * Оѕr + О·m * О·r
	О·n:=vadd[n](vscale[n](-1,conv[n](Оѕm_sh,Оѕr_n)[0..n]),conv[n](О·m_n,О·r_n)[0..n]);
	return (Оі,Оѕn,О·n);
}

// compute (Оі,ПЃ), where ПЃ is a global phase correction
// (matches motlagh-wiebe convention [P,*;Q,*]; https://arxiv.org/abs/2308.01501)
def gqsp_compute_ОіПЃ[d:!в„•](
	P:!в„‚^(d+1),
	Q:!в„‚^(d+1),
):!в„ќ^(d+1)Г—!в„ќ^(d+1)Г—!в„ќ{
	a0s:=sharp[d+1](P);
	b0:=sharp[d+1](Q);
	ПЃ:=a0s[0]/cabs(a0s[0]);
	a0s:=vscale[d+1](1/ПЃ,a0s);
	b0:=vscale[d+1](-1/ПЃ,b0);
	n:=2^(ceil(logв‚‚(d+1)) coerce !в„•);
	(Оіn,Оѕn,О·n):=inlfft[n](pad[n](a0s,0),pad[n](b0,0));
	Оіs:=rev[d+1](vscale[d+1](-1,Оіn[0..d+1]));
	(Оёs,П†s):=vector(2,vector(d+1,0));
	for i in 0..d+1{ (Оёs[i],П†s[i])=(2В·atan(cabs(Оіs[i])),carg(Оіs[i])); }
	return (Оёs,П†s,-carg(ПЃ));
}

def A(Оё:!в„ќ,П†:!в„ќ)(anc:рќ”№):рќ”№{
	with anc:=rotZ(П†,anc){
		anc:=rotY(Оё,anc);
	}
	return anc;
}
def gqsp[d:!в„•](
	Оёs:!в„ќ^(d+1),
	П†s:!в„ќ^(d+1),
	ПЃ:!в„ќ, // global phase correction
)[a:qtype](const f: a в†’mfree a)(cand: a):рќ”№Г—a{	
	anc:=A(Оёs[0],П†s[0])(0:рќ”№);
	for k in 1..d+1 {
		if anc=0 { cand:=f(cand); }
		anc:=A(Оёs[k],П†s[k])(anc);
	}
	phase(ПЃ);
	return (anc,cand);
}

def main(){
	//p:=(0.07,0.35,0.35,0.2);
	//p:=(0.04+0.03i,0.25+0.1i,0.35,0.2);
	p:=(0.03+0.05i,0.25+0.1i,0.35,0.1+0.1i,0.1);
	q:=complement[p.length sub 1](p,1e-8);
	print(q);
	assert(is_complement[128][p.length sub 1](p,q,1e-8));
	angles:=gqsp_compute_ОіПЃ[p.length sub 1](p,q);
	z:=cis(-1/4);
	print(poly_eval[p.length sub 1](p)(z));
	print(poly_eval[q.length sub 1](q)(z));
	return gqsp[p.length sub 1](angles)((x:рќ”№)в‡’rotZ(1/2,x))(0:рќ”№);
}
