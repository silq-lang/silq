// https://arxiv.org/pdf/quant-ph/0410184

def maj(a:đť”ą,b:đť”ą,c:đť”ą){
	bâŠ•=a;
	câŠ•=a;
	aâŠ•=bÂ·c;
	return (a,b,c);
}
def uma(d:đť”ą,ba:đť”ą,ca:đť”ą){
	dâŠ•=baÂ·ca;
	caâŠ•=d;
	baâŠ•=ca;
	return (d,ba,ca);
}

// Fig. 3
def cuccaro_add_simple[n:!â„•](a:uint[n],b:uint[n]){
	if n=0{ return (b,a); }
	(a[0],b[0],x):=maj(a[0],b[0],0);
	for i in [1..n){ (a[i],b[i],a[i-1]):=maj(a[i],b[i],a[i-1]); }
	for i in (n..-1..1]{ (a[i],b[i],a[i-1]):=uma(a[i],b[i],a[i-1]); }
	(a[0],b[0],0):=uma(a[0],b[0],x);
	return (a,b); // (a,s)
}

// Fig. 5
def cuccaro_add[n:!â„•](a:uint[n],b:uint[n]){
	if n<4{ return cuccaro_add_simple(a,b); }
	for i in 1..n{ b[i]âŠ•=a[i]; }
	x:=dup(a[1]);
	xâŠ•=a[0]Â·b[0]; a[1]âŠ•=a[2];
	a[1]âŠ•=xÂ·b[1]; a[2]âŠ•=a[3];
	for i in 2..n-2{ a[i]âŠ•=a[i-1]Â·b[i]; a[i+1]âŠ•=a[i+2]; }
	a[n-2]âŠ•=a[n-3]Â·b[n-2]; /+z:=dup(a[n-1]);+/
	/+zâŠ•=a[n-2]Â·b[n-1];+/ for i in 1..n-1{ b[i]âŠ•=1; }
	b[1]âŠ•=x; for i in 2..n{ b[i]âŠ•=a[i-1]; }
	a[n-2]âŠ•=a[n-3]Â·b[n-2];
	for i in (n-2..-1..2]{ a[i]âŠ•=a[i-1]Â·b[i]; a[i+1]âŠ•=a[i+2]; b[i+1]âŠ•=1; }
	a[1]âŠ•=xÂ·b[1]; a[2]âŠ•=a[3]; b[2]âŠ•=1;
	xâŠ•=a[0]Â·b[0]; a[1]âŠ•=a[2]; b[1]âŠ•=1;
	dup(a[1]):=x;
	for i in 0..n{ b[i]âŠ•=a[i]; }
	return (a,b); // (a,s)
}

n:=4;
def main(){
	for a in 0..2^n{
		for b in 0..2^n{
			assert(cuccaro_add((a,b) as !uint[n]^2) = (a,(a+b)%2^n));
		}
	}
}
