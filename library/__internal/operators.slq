// comparison operators

// a < b
def __lt_b(a: 𝔹, b: 𝔹) @[__operator] lifted: 𝔹 {
	if a {
		return 0;
	}
	return b;
}
def __lt_bB(a: 𝔹, b: !𝔹) @[__operator] lifted: 𝔹 {
	if b {
		return __not_b(a);
	}
	return 0;
}
def __lt_Bb(a: !𝔹, b: 𝔹) @[__operator] lifted: 𝔹 {
	if a {
		return 0;
	}
	return b;
}
def __lt_B(a: !𝔹, b: !𝔹) @[__operator] lifted: !𝔹 {
	if a {
		return 0;
	}
	return b;
}

def __lt_Nb(a: !ℕ, b: 𝔹) @[__operator] lifted: 𝔹 {
	if neq_N0(a) {
		return 0;
	}
	return b;
}
def __lt_bN(a: 𝔹, b: !ℕ) @[__operator] lifted: 𝔹 {
	if __gt_N(b, 1) {
		return 1;
	}
	if __lt_N(b, 1) {
		return 0;
	}
	return dup(a);
}
def __lt_Zb(a: !ℤ, b: 𝔹) @[__operator] lifted: 𝔹 {
	if __lt_Z(a, 0) {
		return 1;
	}
	if __gt_Z(a, 0) {
		return 0;
	}
	return __not_b(b);
}
def __lt_bZ(a: 𝔹, b: !ℤ) @[__operator] lifted: 𝔹 {
	if __lt_Z(b, 1) {
		return 0;
	}
	if __gt_Z(b, 1) {
		return 1;
	}
	return dup(a);
}
def __lt_Qb(a: !ℚ, b: 𝔹) @[__operator] lifted: 𝔹 {
	return __lt_Zb(floor_Q(a), b);
}
def __lt_bQ(a: 𝔹, b: !ℚ) @[__operator] lifted: 𝔹 {
	return __lt_bZ(a, ceil_Q(b));
}
def __lt_Rb(a: !ℝ, b: 𝔹) @[__operator] lifted: 𝔹 {
	return __lt_Zb(floor_R(a), b);
}
def __lt_bR(a: 𝔹, b: !ℝ) @[__operator] lifted: 𝔹 {
	return __lt_bZ(a, ceil_R(b));
}

def __lt_s[n:!ℕ](a: int[n], b: int[n]) @[__operator] lifted: 𝔹 {
