}
def __mod_Bs[n:!ℕ](a: !𝔹, b: int[n]) @[__operator] lifted: int[n] {
	qassert(neq_s0[n](b));
	if !a {
		return 0:int[n];
	}
	if __eq_sN[n](b, 1) {
		return 0:int[n];
	}
	if b < 0 {
		return b + 1;
	} else {
		return 1:int[n];
	}
}
def __mod_bS[n:!ℕ](a: 𝔹, b: !int[n]) @[__operator] lifted: int[n] {
	assert(neq_S0[n](b));
	if __eq_SN[n](b, 1) {
		return 0:!int[n];
	}
	return qubit_to_int[n](a);
}
