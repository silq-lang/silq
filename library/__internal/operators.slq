def __mod_Zu[n:!ℕ](a: !ℤ, b: uint[n]) @[__operator] lifted: uint[n] {
	(a_sign, a1) := int_sign_abs(a);
	(q, r) := qint_udivmod_cq[n](a1, b as B^n);
	if a_sign {
		adj := X(qint_eqc[n](r, 0));
		r := qint_neg[n](r);
		if adj {
			r := qint_iaddq[n](r, b as B^n);
		}
		qint_eqc[n](r, 0) := X(adj);
	}
	return r as uint[n];
}
