}
def __lt_sN[n:!ℕ](a: int[n], b: !ℕ) @[__operator] lifted: 𝔹 {
	p := pow2(__nsub_N(n, 1));
	if __ge_N(b, p) {
		return 1;
	}
	return __lt_sZ_unchecked[n](a, b);
}
def __lt_Zs[n:!ℕ](a: !ℤ, b: int[n]) @[__operator] lifted: 𝔹 {
	return X(__le_sZ[n](b, a));
}
def __lt_sZ[n:!ℕ](a: int[n], b: !ℤ) @[__operator] lifted: 𝔹 {
	p := pow2(__nsub_N(n, 1));
	if __lt_Z(b, __uminus_Z(p)) {
		return 0;
	}
	if __ge_Z(b, p) {
		return 1;
	}
	return __lt_sZ_unchecked[n](a, b);
}
def __lt_sZ_unchecked[n:!ℕ](a: int[n], b: !ℤ) @[__operator] lifted: 𝔹 {
