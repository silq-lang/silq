// binary assignment operators

// a+=b
def __add_assign_s[n:!ℕ](a: int[n], const b: int[n]) @[__operator] qfree: int[n] {
	return qint_iaddq[n](a as B^n, b as B^n) as int[n];
}
def __add_assign_sS[n:!ℕ](a: int[n], const b: !int[n]) @[__operator] qfree: int[n] {
	return __add_assign_sZ[n](a, b as !Z);
}

def __add_assign_sb[n:!ℕ](a: int[n], const b: 𝔹) @[__operator] qfree: int[n] {
	return __add_assign_s[n](a, qubit_to_int[n](b));
}
def __add_assign_sB[n:!ℕ](a: int[n], const b: !𝔹) @[__operator] qfree: int[n] {
	if b {
		a := __add_assign_sZ[n](a, 1);
	}
	return a;
}

def __add_assign_sZ[n:!ℕ](a: int[n], const b: !ℤ) @[__operator] qfree: int[n] {
	return qint_iaddc[n](a as B^n, b) as int[n];
}

def __add_assign_u[n:!ℕ](a: uint[n], const b: uint[n]) @[__operator] qfree: uint[n] {
	return qint_iaddq[n](a as B^n, b as B^n) as uint[n];
}
def __add_assign_uU[n:!ℕ](a: uint[n], const b: !uint[n]) @[__operator] qfree: uint[n] {
	return __add_assign_uZ[n](a, b as !N);
}

def __add_assign_ub[n:!ℕ](a: uint[n], const b: 𝔹) @[__operator] qfree: uint[n] {
	return __add_assign_u[n](a, qubit_to_uint[n](b));
}
def __add_assign_uB[n:!ℕ](a: uint[n], const b: !𝔹) @[__operator] qfree: uint[n] {
	if b {
		a := __add_assign_uZ[n](a, 1);
	}
	return a;
}

def __add_assign_uZ[n:!ℕ](a: uint[n], const b: !ℤ) @[__operator] qfree: uint[n] {
	return qint_iaddc[n](a as B^n, b) as uint[n];
}

// a-=b
def __sub_assign_s[n:!ℕ](a: int[n], const b: int[n]) @[__operator] qfree: int[n] {
	return qint_isubq[n](a as B^n, b as B^n) as int[n];
}
def __sub_assign_sS[n:!ℕ](a: int[n], const b: !int[n]) @[__operator] qfree: int[n] {
	return __sub_assign_sZ[n](a, b as !Z);
}

def __sub_assign_sb[n:!ℕ](a: int[n], const b: 𝔹) @[__operator] qfree: int[n] {
	return __sub_assign_s[n](a, qubit_to_int[n](b));
}
def __sub_assign_sB[n:!ℕ](a: int[n], const b: !𝔹) @[__operator] qfree: int[n] {
	if b {
		a := __sub_assign_sZ[n](a, 1);
	}
	return a;
}

def __sub_assign_sZ[n:!ℕ](a: int[n], const b: !ℤ) @[__operator] qfree: int[n] {
	return qint_isubc[n](a as B^n, b) as int[n];
}

def __sub_assign_u[n:!ℕ](a: uint[n], const b: uint[n]) @[__operator] qfree: uint[n] {
	return qint_isubq[n](a as B^n, b as B^n) as uint[n];
}
def __sub_assign_uU[n:!ℕ](a: uint[n], const b: !uint[n]) @[__operator] qfree: uint[n] {
	return __sub_assign_uZ[n](a, b as !N);
}

def __sub_assign_ub[n:!ℕ](a: uint[n], const b: 𝔹) @[__operator] qfree: uint[n] {
	return __sub_assign_u[n](a, qubit_to_uint[n](b));
}
def __sub_assign_uB[n:!ℕ](a: uint[n], const b: !𝔹) @[__operator] qfree: uint[n] {
	if b {
		a := __sub_assign_uZ[n](a, 1);
	}
	return a;
}

def __sub_assign_uZ[n:!ℕ](a: uint[n], const b: !ℤ) @[__operator] qfree: uint[n] {
	return qint_isubc[n](a as B^n, b) as uint[n];
}

// a nsub= b
// def __nsub_assign_s[n:!ℕ](a:int[n],const b:int[n])qfree:uint[n];
// def __nsub_assign_sS[n:!ℕ](a:int[n],const b:!int[n])qfree:uint[n];

// def __nsub_assign_sb[n:!ℕ](a:int[n],const b:𝔹)qfree:uint[n];
// def __nsub_assign_sB[n:!ℕ](a:int[n],const b:!𝔹)qfree:uint[n];

// def __nsub_assign_sZ[n:!ℕ](a:int[n],const b:!ℤ)qfree:uint[n];

def __nsub_assign_u[n:!ℕ](a: uint[n], const b: uint[n]) @[__operator] qfree: uint[n] {
	qassert(__ge_u[n](a, b));
	return __sub_assign_u[n](a, b);
}
def __nsub_assign_uU[n:!ℕ](a: uint[n], const b: !uint[n]) @[__operator] qfree: uint[n] {
	return __nsub_assign_uZ[n](a, b as !Z);
}

def __nsub_assign_ub[n:!ℕ](a: uint[n], const b: 𝔹) @[__operator] qfree: uint[n] {
	qassert(__orb_b(neq_u0[n](a), __not_b(b)));
	return __sub_assign_ub[n](a, b);
}
def __nsub_assign_uB[n:!ℕ](a: uint[n], const b: !𝔹) @[__operator] qfree: uint[n] {
	if !b {
		return a;
	}
	qassert(neq_u0[n](a));
	return __sub_assign_uZ[n](a, b);
}
def __nsub_assign_uZ[n:!ℕ](a: uint[n], const b: !ℤ) @[__operator] qfree: uint[n] {
	qassert(__ge_uZ[n](a, b));
	return __sub_assign_uZ[n](a, b);
}

def __nsub_assign_b(a: 𝔹, const b: 𝔹) @[__operator] qfree: 𝔹 {
	if b {
		1 := a;
		a := 0;
	}
	return a;
}
def __nsub_assign_bB(a: 𝔹, const b: !𝔹) @[__operator] qfree: 𝔹 {
	if b {
		1 := a;
		a := 0;
	}
	return a;
}
def __nsub_assign_bN(a: 𝔹, const b: !ℕ) @[__operator] qfree: 𝔹 {
	assert(__le_N(b, 1));
	if neq_N0(b) {
		1 := a;
		a := 0;
	}
	return a;
}

// a·=b
// (always rewritten to with x:=a do x=x·b)

// a/=b
// (always rewritten to with x:=a do x=x/b)

// a div= b
// (always rewritten to with x:=a do x=x div b)

// a %= b
// (always rewritten to with x:=a do x=x%b)

// a ^= b
// (always rewritten to with x:=a do x=x^b)

// a ~= b
// (always rewritten to with x:=a do x:=x~b)

// a |= b
// (always rewritten to with x:=a do x=x|b)

// a ⊕= b
def __xorb_assign_s[n:!ℕ](a: int[n], const b: int[n]) @[__operator] qfree: int[n] {
	return qint_ixorq[n](a as B^n, b as B^n) as int[n];
}
def __xorb_assign_sS[n:!ℕ](a: int[n], const b: !int[n]) @[__operator] qfree: int[n] {
	return __xorb_assign_sZ[n](a, b as !Z);
}

def __xorb_assign_sb[n:!ℕ](a: int[n], const b: 𝔹) @[__operator] qfree: int[n] {
	return __xorb_assign_s[n](a, qubit_to_int[n](b));
}
def __xorb_assign_sB[n:!ℕ](a: int[n], const b: !𝔹) @[__operator] qfree: int[n] {
	if b {
		a := __xorb_assign_sZ[n](a, 1);
	}
	return a;
}

def __xorb_assign_sZ[n:!ℕ](a: int[n], const b: !ℤ) @[__operator] qfree: int[n] {
	return qint_ixorc[n](a as B^n, b) as int[n];
}

def __xorb_assign_u[n:!ℕ](a: uint[n], const b: uint[n]) @[__operator] qfree: uint[n] {
	return qint_ixorq[n](a as B^n, b as B^n) as uint[n];
}
def __xorb_assign_uU[n:!ℕ](a: uint[n], const b: !uint[n]) @[__operator] qfree: uint[n] {
	return __xorb_assign_uZ[n](a, b as !N);
}

def __xorb_assign_ub[n:!ℕ](a: uint[n], const b: 𝔹) @[__operator] qfree: uint[n] {
	return __xorb_assign_u[n](a, qubit_to_uint[n](b));
}
def __xorb_assign_uB[n:!ℕ](a: uint[n], const b: !𝔹) @[__operator] qfree: uint[n] {
	if b {
		a := __xorb_assign_uZ[n](a, 1);
	}
	return a;
}

def __xorb_assign_uZ[n:!ℕ](a: uint[n], const b: !ℤ) @[__operator] qfree: uint[n] {
	return qint_ixorc[n](a as B^n, b) as uint[n];
}

def __xorb_assign_b(a: 𝔹, const b: 𝔹) @[__operator] qfree: 𝔹 {
	if b {
		a := X(a);
	}
	return a;
}
def __xorb_assign_bB(a: 𝔹, const b: !𝔹) @[__operator] qfree: 𝔹 {
	if b {
		a := X(a);
	}
	return a;
}

// a &= b
// (always rewritten to with x:=a do x=x&b)


// quantum indexing
def __qindex_ab[a:qtype](const xs: a[], const idx: 𝔹) {
	if idx {
		if xs.length < 2 {
			return __qabort(a);
		} else {
			return xs[1];
		}
	} else {
		if xs.length == 0 {
			return __qabort(a);
		} else {
			return xs[0];
		}
	}
}
def __qindex_vb[a:qtype,n:!ℕ](const xs: a^n, const idx: 𝔹) {
	if idx {
		if n < 2 {
			return __qabort(a);
		} else {
			return xs[1];
		}
	} else {
		if n == 0 {
			return __qabort(a);
		} else {
			return xs[0];
		}
	}
}

def __qindex_au[a:qtype,m:!ℕ](const xs: a[], const idx: uint[m]) {
	n := xs.length;
	return __qindex_vu(xs coerce a^n, idx);
}
def __qindex_as[a:qtype,m:!ℕ](const xs: a[], const idx: int[m]) {
	n := xs.length;
	return __qindex_vs(xs coerce a^n, idx);
}

def __qindex_vu[a:qtype,n:!ℕ,m:!ℕ](const xs: a^n, const idx: uint[m]) {
	assert(n > 0);
	def rec(k:!ℕ, cidx:!uint[m]) {
		if k == m{
			return xs[cidx];
		} else if idx[k] {
			cidx[k] = 1;
			return if cidx>=n then __qabort(a) else rec(k+1,cidx);
		} else {
			return rec(k+1, cidx);
		}
	}
	return rec(0, 0:!uint[m]);
}
def __qindex_vs[a:qtype,n:!ℕ,m:!ℕ](const xs: a^n, const idx: int[m]){
	if m == 0 { return xs[0]; }
	bits ~ (s,) := idx as 𝔹^m;
	forget(s = 0);
	return __qindex_vu(xs, bits as uint[m sub 1]);
}
