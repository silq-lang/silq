def __pow_R_unchecked(a: !ℝ, b: !ℝ) @[__operator, extern="primitive.real.powf"] lifted: !ℝ;
def __pow_R(a: !ℝ, b: !ℝ) @[__operator] lifted: !ℝ {
	assert(a >= 0 || b == floor_R(b));
	return __pow_R_unchecked(a, b);
}

def __pow_CB(a: !ℂ, b: !𝔹) @[__operator] lifted: !ℂ {
	return if b then a else 1;
}
def __pow_CN(a: !ℂ, b: !ℕ) @[__operator] lifted: !ℂ {
	(r, x, c) := (1:!ℂ, a, b);
	while c ≠ 0 {
		if c&1 {
			r = __mul_C(r, x);
		}
		x = __mul_C(x, x);
		c = c div 2;
	}
	return r;
}
def __pow_CZ(a: !ℂ, b: !ℤ) @[__operator] lifted: !ℂ {
	return if b < 0 then __pow_CN(cinv(a), -b coerce !ℕ) else __pow_CN(a, b coerce !ℕ);
}

