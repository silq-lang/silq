def __mul_R(a: !ℝ, b: !ℝ) @[__operator, extern="primitive.real.mul"] lifted: !ℝ;
def __mul_CR(a: !ℂ, b: !ℝ) @[__operator] lifted: !ℂ {
	(a_re, a_im) := ctori(a);
	return cfromri(a_re·b, a_im·b);
}
def __mul_RC(a: !ℝ, b: !ℂ) @[__operator] lifted: !ℂ {
	(b_re, b_im) := ctori(b);
	return cfromri(a·b_re, a·b_im);
}
def __mul_C(a: !ℂ, b: !ℂ) @[__operator] lifted: !ℂ {
	(a_re, a_im) := ctori(a);
	(b_re, b_im) := ctori(b);
	return cfromri(a_re·b_re - a_im·b_im, a_re·b_im + a_im·b_re);
}

// a/b

def __div_B(a: !𝔹, b: !𝔹) @[__operator] lifted: !ℚ {
	return __idiv_B(a, b);
}
def __div_N(a: !ℕ, b: !ℕ) @[__operator] lifted: !ℚ {
	return __div_Q(a, b);
}
def __div_Z(a: !ℤ, b: !ℤ) @[__operator] lifted: !ℚ {
	return __div_Q(a, b);
}
def __div_Q(a: !ℚ, b: !ℚ) @[__operator, extern="primitive.rational.div"] lifted: !ℚ;
def __div_R(a: !ℝ, b: !ℝ) @[__operator, extern="primitive.real.div"] lifted: !ℝ;
def __div_CR(a: !ℂ, b: !ℝ) @[__operator] lifted: !ℂ {
	(a_re, a_im) := ctori(a);
	return cfromri(a_re/b, a_im/b);
}
def __div_RC(a: !ℝ, b: !ℂ) @[__operator] lifted: !ℂ {
	(b_re, b_im) := ctori(b);
	denom := b_re^2 + b_im^2;
	return cfromri((a·b_re)/denom, (-a·b_im)/denom);
}
def __div_C(a: !ℂ, b: !ℂ) @[__operator] lifted: !ℂ {
	(a_re, a_im) := ctori(a);
	(b_re, b_im) := ctori(b);
	denom := b_re^2 + b_im^2;
	return cfromri((a_re·b_re + a_im·b_im)/denom, (a_im·b_re - a_re·b_im)/denom);
}

// a div b
def __idiv_s[n:!ℕ](a: int[n], b: int[n]) @[__operator] lifted: int[n] {
	(a_sign, a1) := qint_sign_abs[n](a);
	(b_sign, b1) := qint_sign_abs[n](b);
	(q, r) := qint_udivmod_qq[n, n](a1, b1);
	adj := __xorb_b(a_sign, b_sign);
	if adj {
		q := qint_neg[n](q);
	}
	if qint_eqc[n](r, 0) {
		adj = 0;
	}
	if adj {
		q := qint_isubc[n](q, 1);
	}
	return q as int[n];
}
def __idiv_Ss[n:!ℕ](a: !int[n], b: int[n]) @[__operator] lifted: int[n] {
	return __idiv_Zs[n](a as !Z, b);
}
def __idiv_sS[n:!ℕ](a: int[n], b: !int[n]) @[__operator] lifted: int[n] {
	return __idiv_sZ[n](a, b as !Z);
}
