	return __mod_Z(a, b as !Z) as !int[n];
}

def __mod_sN[n:!ℕ](a: int[n], b: !ℕ) @[__operator] lifted: int[n] {
	(a_sign, a1) := qint_sign_abs[n](a);
	(q, r) := qint_udivmod_qc[n](a1, b);
	if qint_eqc[n](r, 0) {
		adj := 0;
	} else {
		adj := dup(a_sign);
	}
	if a_sign {
		r := qint_neg[n](r);
	}
	if adj {
		r := qint_iaddc[n](r, b);
	}
	if qint_eqc[n](r, 0) {
		0 := adj;
	} else {
		dup(a_sign) := adj;
	}
	return r as int[n];
}
def __mod_SN[n:!ℕ](a: !int[n], b: !ℕ) @[__operator] lifted: !int[n] {
	return __mod_Z(a as !Z, b) as !int[n];
