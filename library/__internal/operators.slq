}
def __idiv_Bs[n:!ℕ](a: !𝔹, b: int[n]) @[__operator] lifted: int[n] {
	qassert(neq_s0[n](b));
	if !a {
		return 0:int[n];
	}
	if __lt_sZ[n](b, 0) {
		return (-1):int[n];
	}
	if __gt_sZ[n](b, 1) {
		return 0:int[n];
	}
	return 1:int[n];
}
def __idiv_bS[n:!ℕ](a: 𝔹, b: !int[n]) @[__operator] lifted: int[n] {
	assert(neq_S0[n](b));
	if !a {
		return 0:int[n];
	}
