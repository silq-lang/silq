	}
	if __gt_SZ[n](b, 1) {
		return 0:!int[n];
	}
	return 1:!int[n];
}

def __idiv_sN[n:!ℕ](a: int[n], b: !ℕ) @[__operator] lifted: int[n] {
	(a_sign, a1) := qint_sign_abs[n](a);
	(q, r) := qint_udivmod_qc[n](a1, b);
	if a_sign {
		q := qint_neg[n](q);
	}
	if qint_eqc[n](r, 0) {
		adj := 0;
	} else {
		adj := a_sign;
	}
	if adj {
		q := qint_isubc[n](q, 1);
	}
	return q as int[n];
}
def __idiv_SN[n:!ℕ](a: !int[n], b: !ℕ) @[__operator] lifted: !int[n] {
	return __idiv_Z(a as !Z, b) as !int[n];
}
