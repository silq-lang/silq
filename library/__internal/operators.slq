def __mod_sZ[n:!ℕ](a: int[n], b: !ℤ) @[__operator] lifted: int[n] {
	(a_sign, a1) := qint_sign_abs[n](a);
	(b_sign, b1) := int_sign_abs(b);
	(q, r) := qint_udivmod_qc[n](a1, b1);
	if qint_eqc[n](r, 0) {
		adj := 0;
	} else {
		adj := __xorb_b(a_sign, b_sign);
	}
	if a_sign {
		r := qint_neg[n](r);
	}
	if adj {
		r := qint_iaddc[n](r, b);
	}
	if qint_eqc[n](r, 0) {
