// prototypes and implementations of Silq operators

// helpers
def qassert(cond: B): unit {
	forget(cond=1);
}
def qubit_to_int[n:!N](v: B) lifted: int[n] {
	// Is -0.5 the only int[0] value?
	return ([dup(v)] ~ vector(n sub 1, 0)) as int[n];
}
def qubit_to_uint[n:!N](v: B) lifted: uint[n] {
	if __eq_N(n, 0) {
		return 0:uint[n];
	}
	return ([dup(v)] ~ vector(n sub 1, 0)) as uint[n];
}
def pow2(n: !N) lifted: !N {
	return __pow_N(2, n);
}
def pow2m1(n: !N) lifted: !N {
	return __nsub_Z_unchecked(pow2(n), 1);
}

def floor_Q(a: !Q) @[extern="primitive.rational.floor"] lifted: !Z;
def floor_R(a: !R) @[extern="primitive.real.floor"] lifted: !Z;
def ceil_Q(a: !Q) @[extern="primitive.rational.ceil"] lifted: !Z;
def ceil_R(a: !R) @[extern="primitive.real.ceil"] lifted: !Z;

def uint_bits(n: !N) lifted: !N {
	if __le_N(n, 1) {
		return n;
	}
	return 1 + uint_bits(__idiv_N(n, 2));
}

def sint_bits(n: !Z) lifted: !N {
	if __lt_Z(n, 0) {
		sign := -1;
	} else {
		sign := 0;
	}
	return 1 + uint_bits((n xorb sign) coerce !N);
}

def unchecked_nat(n: !Z) lifted: !N {
	// TODO make unchecked
	return n coerce !N;
}

def int_sign_abs(n: !Z) lifted: !B x !N {
	if __lt_Z(n, 0) {
		return (1, unchecked_nat(__uminus_Z(n)));
	} else {
		return (0, unchecked_nat(n));
	}
}

def int_Q(a: !Q) lifted: !B x !Z { // TOOD use a sum type
	r := floor_Q(a);
	if __eq_Q(a, r as !Q) {
		return (1, r);
	}
	return (0, 0);
}
def int_R(a: !R) lifted: !B x !Z { // TOOD use a sum type
	r := floor_R(a);
	if __eq_R(a, r as !Q) {
		return (1, r);
	}
	return (0, 0);
}

def neq_N0(a: !N) lifted: !B {
	return __neq_N(a, 0);
}
def neq_Z0(a: !Z) lifted: !B {
	return __neq_Z(a, 0);
}
def neq_s0[n:!N](a: int[n]) lifted: B {
	return X(qint_eqc[n](a as B^n, 0));
}
def neq_S0[n:!N](a: !int[n]) lifted: !B {
	return neq_Z0(a as !Z);
}
def neq_u0[n:!N](a: uint[n]) lifted: B {
	return X(qint_eqc[n](a as B^n, 0));
}
def neq_U0[n:!N](a: !uint[n]) lifted: !B {
	return neq_N0(a as !N);
}

def __bit_Z(a: !Z, i: !N) lifted: !B {
	return neq_Z0(__andb_Z(a, pow2(i)));
}

def qint_neg[n:!N](a: B^n) @[__operator] qfree: B^n {
	return qint_irsubc[n](0, a);
}

def qint_sign_abs[n:!N](a: int[n]) qfree: B x B^n {
	a := a as B^n;
	sign := dup(a[n sub 1]);
	if sign {
		a := qint_neg[n](a);
	}
	return (sign, a);
}

def qint_not[n:!N](a: B^n) @[__operator] qfree: B^n {
	return qint_ixorc(a, -1);
}

def qint_iaddc[n:!N](a: B^n, const b: !Z) @[__operator] @noinline @nogarbage @[extern="silq_builtin.iaddc"] qfree: B^n {
	def rec(a: B[], const c0: B) qfree: B[] {
		m := a.length;
		if m == 0 {
			return a;
		}
		[a0] ~ a := a;
		b0 := __bit_Z(b, n sub m);
		a0 xorb= b0;
		a := rec(a, if a0 then c0 else b0);
		a0 xorb= c0;
		return [a0] ~ a;
	}
	return rec(a, 0) coerce B^n;
}

def qint_iaddq[n:!N](a: B^n, const b: B^n) @[__operator] @noinline @nogarbage @[extern="silq_builtin.iaddq"] qfree: B^n {
	def rec(a: B[], const b: B^n, const c0: B) qfree: B[] {
		m := a.length;
		if m == 0 {
			return a;
		}
		[a0] ~  a := a;
		b0 := b[n sub m];
		a0 xorb= b0;
		a := rec(a, b, if a0 then c0 else b0);
		a0 xorb= c0;
		return [a0] ~ a;
	}
	return rec(a, b, 0) coerce B^n;
}

def qint_isubc[n:!N](a: B^n, const b: !Z) @[__operator] qfree: B^n {
	qint_iaddc[n](a, b) := a;
	return a;
}

def qint_irsubc[n:!N](const a: !Z, b: B^n) @[__operator] @nogarbage qfree: B^n {
	def rec(b: B[], const c0: B) qfree: B[] {
		m := b.length;
		if m == 0 {
			return b;
		}
		[b0] ~ b := b;
		a0 := __bit_Z(a, n sub m);
		b0 xorb= a0;
		b := rec(b, if b0 then !a0 else c0);
		b0 xorb= c0;
		return [b0] ~ b;
	}
	return rec(b, 0) coerce B^n;
}

def qint_isubq[n:!N](a: B^n, const b: B^n) qfree: B^n {
	qint_iaddq[n](r, b) := a;
	return r;
}

def qint_mulc[n:!N](a: B^n, b: !Z) lifted: B^n {
	if n == 0 {
		return vector(n, 0);
	}
	if n == 1 {
		if __andb_Z(b, 1) coerce !B {
			return a;
		}
		return vector(n, 0);
	}
	r := qint_mulc[n sub 1](a[0..n sub 1], b div 2);
	b0 := __andb_Z(b, 1) coerce !B;
	if b0 {
		r := qint_iaddq[n sub 1](r, a[1..n]);
		rlo := a[0];
	} else {
		rlo := 0;
	}
	return [rlo] ~ r;
}

def qint_mulq[n:!N](const a: B^n, const b: B^n) @nogarbage qfree: B^n {
	if n == 0 {
		return vector(n, 0);
	}
	if n == 1 {
		if b[0] {
			return a;
		}
		return vector(n, 0);
	}
	r := qint_mulq[n sub 1](a[0..n sub 1], b[1..n]);
	b0 := b[0];
	if b0 {
		r := qint_iaddq[n sub 1](r, a[1..n]);
		rlo := a[0];
	} else {
		rlo := 0;
	}
	return [rlo] ~ r;
}

def qint_udivmod_qq[n:!N,m:!N](const a: B^n, const b: B^m) @nogarbage qfree: B^n x B^m {
	if n == 0 || m <= 1 {
		return (a, vector(m, 0));
	}
	(q1, r1) := qint_udivmod_qq[n sub 1, m](a[1..n], b);
	r := [a[0]] ~ r1;
	lo := X(qint_ultq[m+1](r, b ~ [0]));
	r = r[0..m];
	if lo {
		r := qint_isubq[m](r, b);
	}
	q := [lo] ~ q1;
	return (q, r);
}

def qint_udivmod_qc[n:!N](a: B^n, b: !N) @nogarbage lifted: B^n x B^n {
	if b >= pow2(n) {
		return (vector(n, 0), a);
	}
	m := uint_bits(b);

	def rec(a: B[], b: !N) lifted: B[] x B^m {
		if a.length == 0 || m <= 1 {
			return (a, vector(m, 0));
		}
		[a0] ~ a' := dup(a);
		(q1, r1) := rec(a', b);
		r := [a0] ~ r1;
		lo := X(qint_ultc[m+1](r, b));
		r = r[0..m];
		if lo {
			r := qint_isubc[m](r, b);
		}
		q := [lo] ~ q1;
		return (q, r);
	}

	(q, r) := rec(a, b);
	q := q coerce B^n;
	return (q, r ~ vector(n sub m, 0));
}

def qint_udivmod_cq[m:!N](a: !N, b: B^m) @nogarbage lifted: B^m x B^m {
	n := uint_bits(a);
	(q, r) := qint_udivmod_qq[n,m](a as uint[n] as B^n, b);
	if m < n {
		return (q[0..m], r);
	} else {
		return (q ~ vector(m sub n, 0), r);
	}
}

def qint_orc[n:!N](a: B^n, b: !Z) lifted: B^n {
	def rec(m: !N, a: B^n) lifted: B^m {
		if m == 0 {
			return () coerce B^m;
		}
		r := rec(m sub 1, a);
		return r ~ [__orb_bB(a[m sub 1], __bit_Z(b, m sub 1))];
	}
	return rec(n, a);
}

def qint_orq[n:!N](a: B^n, b: B^n) lifted: B^n {
	def rec(m: !N, a: B^n, b: B^n) lifted: B^m {
		if m == 0 {
			return () coerce B^m;
		}
		r := rec(m sub 1, a, b);
		return r ~ [__orb_b(a[m sub 1], b[m sub 1])];
	}
	return rec(n, a, b);
}

def qint_ixorc[n:!N](a: B^n, const b: !Z) qfree: B^n {
	def rec(a: B[]) qfree: B[] {
		m := a.length;
		if m == 0 {
			return a;
		}
		[a0] ~ a := a;
		a0 xorb= __bit_Z(b, n sub m);
		a := rec(a);
		return [a0] ~ a;
	}
	return rec(a) coerce B^n;
}

def qint_ixorq[n:!N](a: B^n, const b: B^n) qfree: B^n {
	def rec(a: B[], const b: B^n) qfree: B[] {
		m := a.length;
		if m == 0 {
			return a;
		}
		[a0] ~ a := a;
		a0 xorb= b[n sub m];
		a := rec(a, b);
		return [a0] ~ a;
	}
	return rec(a, b) coerce B^n;
}

def qint_andc[n:!N](a: B^n, b: !Z) lifted: B^n {
	def rec(m: !N, a: B^n) lifted: B^m {
		if m == 0 {
			return () coerce B^m;
		}
		r := rec(m sub 1, a);
		return r ~ [__andb_bB(a[m sub 1], __bit_Z(b, m sub 1))];
	}
	return rec(n, a);
}

def qint_andq[n:!N](a: B^n, b: B^n) lifted: B^n {
	def rec(m: !N, a: B^n, b: B^n) lifted: B^m {
		if m == 0 {
			return () coerce B^m;
		}
		r := rec(m sub 1, a, b);
		return r ~ [__andb_b(a[m sub 1], b[m sub 1])];
	}
	return rec(n, a, b);
}

def qint_eqc[n:!N](a: B^n, b: !Z) @noinline @[extern="silq_builtin.ieqc"] lifted: B {
	def rec(a: B^n, i: !N) lifted: B {
		if i == n {
			return 1;
		}
		rest := rec(a, i+1);
		return __andb_b(__eq_bB(a[i], __bit_Z(b, i)), rest);
	}
	return rec(a, 0);
}

def qint_eqq[n:!N](a: B^n, b: B^n) @noinline @[extern="silq_builtin.ieqq"] lifted: B {
	def rec(a: B^n, b: B^n, i: !N) lifted: B {
		if i == n {
			return 1;
		}
		rest := rec(a, b, i+1);
		return __andb_b(__eq_b(a[i], b[i]), rest);
	}
	return rec(a, b, 0);
}

def qint_ltc_step(a: B, b: !B, rest: B) lifted: B {
	if b {
		if a {
			return rest;
		} else {
			return 1;
		}
	} else {
		if a {
			return 0;
		} else {
			return rest;
		}
	}
}

def qint_ultc[n:!N](a: B^n, b: !Z) @noinline @[extern="silq_builtin.iltc"] lifted: B {
	def rec(const a: B^n, i: !N) qfree: B {
		if i == 0 {
			return 0;
		}
		i sub= 1;
		return qint_ltc_step(a[i], __bit_Z(b, i), rec(a, i));
	}
	return rec(a, n);
}

def qint_sltc[n:!N](a: B^n, b: !Z) lifted: B {
	a' := dup(a);
	a'[n sub 1] xorb= 1;
	return qint_ultc[n](a', b + 2^(n sub 1));
}

def qint_ltq_step(a: B, b: B, rest: B) lifted: B {
	if b {
		if a {
			return rest;
		} else {
			return 1;
		}
	} else {
		if a {
			return 0;
		} else {
			return rest;
		}
	}
}

def qint_ultq[n:!N](a: B^n, b: B^n) @[extern="silq_builtin.iltq"] lifted: B {
	def rec(const a: B^n, const b: B^n, i: !N) qfree: B {
		if i == 0 {
			return 0;
		}
		i sub= 1;
		rest := rec(a, b, i);
		return qint_ltq_step(a[i], b[i], rec(a, b, i));
	}
	return rec(a, b, n);
}

def qint_sltq[n:!N](a: B^n, b: B^n) lifted: B {
	a' := dup(a);
	a'[n sub 1] xorb= 1;
	b' := dup(b);
	b'[n sub 1] xorb= 1;
	return qint_ultq[n](a', b');
}

// unary operators

// !b
def __not_b(a: 𝔹) @[__operator] lifted: 𝔹 {
	if a {
		return 0;
	} else {
		return 1;
	}
}
def __not_B(a: !𝔹) @[__operator] lifted: !𝔹 {
	if a {
		return 0:!B;
	} else {
		return 1:!B;
	}
}

// -x
def __uminus_s[n:!ℕ](a: int[n]) @[__operator] lifted: int[n] {
	return qint_neg[n](a as B^n) as int[n];
}
def __uminus_S[n:!ℕ](x: !int[n]) @[__operator] lifted: !int[n] {
	return __uminus_Z(x as !Z) as !int[n];
}
def __uminus_u[n:!ℕ](a: uint[n]) @[__operator] lifted: uint[n] {
	return qint_neg[n](a as B^n) as uint[n];
}
def __uminus_U[n:!ℕ](x: !uint[n]) @[__operator] lifted: !uint[n] {
	return __uminus_Z(x as !N) as !uint[n];
}

def __uminus_B(x:!𝔹)lifted:!ℤ {
	return if x { -(1:!Z) } else { 1:!Z };
}
def __uminus_N(x: !ℕ) @[__operator, extern="primitive.int.neg"] lifted: !ℤ;
def __uminus_Z(x: !ℤ) @[__operator, extern="primitive.int.neg"] lifted: !ℤ;
def __uminus_Q(x: !ℚ) @[__operator, extern="primitive.rational.neg"] lifted: !ℚ;
def __uminus_R(x: !ℝ) @[__operator, extern="primitive.real.neg"] lifted: !ℝ;
def __uminus_C(x: !ℂ) @[__operator] lifted: !ℂ {
	(re, im) := ctori(x);
	return cfromri(-re, -im);
}

// ~x
def __bitnot_b(x: 𝔹) @[__operator] lifted: 𝔹 {
	return __not_b(x);
}
def __bitnot_B(x: !𝔹) @[__operator] lifted: !𝔹 {
	return __not_B(x);
}

def __bitnot_s[n:!ℕ](x: int[n]) @[__operator] lifted: int[n] {
	return qint_not[n](x as B^n) as int[n];
}
def __bitnot_S[n:!ℕ](x: !int[n]) @[__operator] lifted: !int[n] {
	def impl(x: !Z, y: !int[n]) @[extern="primitive.int.neg"] qfree: !int[n];
	return impl(-1, x);
}
def __bitnot_u[n:!ℕ](x: uint[n]) @[__operator] lifted: uint[n] {
	return qint_not[n](x as B^n) as uint[n];
}
def __bitnot_U[n:!ℕ](x: !uint[n]) @[__operator] lifted: !uint[n] {
	def impl(x: !N, y: !uint[n]) @[extern="primitive.int.neg"] qfree: !uint[n];
	return impl(pow2m1(n), x);
}

def __bitnot_N(x: !ℕ) @[__operator] lifted: !ℤ {
	return __bitnot_Z(x);
}
def __bitnot_Z(x: !ℤ) @[__operator] lifted: !ℤ {
	return __sub_Z(-1, x);
}
// def __bitnot_Q(x:!ℚ)lifted:!ℚ; // TODO?
// def __bitnot_R(x:!ℝ)lifted:!ℝ; // TODO?
// def __bitnot_C(x:!ℂ)lifted:!ℂ; // TODO?


// binary operators
// a+b
def __add_s[n:!ℕ](a: int[n], b: int[n]) @[__operator] lifted: int[n] {
	return qint_iaddq[n](dup(a) as B^n, b as B^n) as int[n];
}
def __add_Ss[n:!ℕ](a: !int[n], b: int[n]) @[__operator] lifted: int[n] {
	return __add_sZ[n](b, a as !Z);
}
def __add_sS[n:!ℕ](a: int[n], b: !int[n]) @[__operator] lifted: int[n] {
	return __add_sZ[n](a, b as !Z);
}
def __add_S[n:!ℕ](a: !int[n], b: !int[n]) @[__operator] lifted: !int[n] {
	return __add_Z(a as !Z, b as !Z) as !int[n];
}

def __add_sb[n:!ℕ](a: int[n], b: 𝔹) @[__operator] lifted: int[n] {
	return __add_s[n](a, qubit_to_int[n](b));
}
def __add_Sb[n:!ℕ](a: !int[n], b: 𝔹) @[__operator] lifted: int[n] {
	if !b {
		return a as int[n];
	}
	return __add_Z(a as !Z, 1) as int[n];
}
def __add_sB[n:!ℕ](a: int[n], b: !𝔹) @[__operator] lifted: int[n] {
	if !b {
		return dup(a);
	}
	return __add_sZ[n](a, 1);
}
def __add_SB[n:!ℕ](a: !int[n], b: !𝔹) @[__operator] lifted: !int[n] {
	if !b {
		return a;
	}
	return __add_Z(a as !Z, 1) as !int[n];
}

def __add_bs[n:!ℕ](a: 𝔹, b: int[n]) @[__operator] lifted: int[n] {
	return __add_sb[n](b, a);
}
def __add_Bs[n:!ℕ](a: !𝔹, b: int[n]) @[__operator] lifted: int[n] {
	return __add_sB[n](b, a);
}
def __add_bS[n:!ℕ](a: 𝔹, b: !int[n]) @[__operator] lifted: int[n] {
	return __add_Sb[n](b, a);
}
def __add_BS[n:!ℕ](a: !𝔹, b: !int[n]) @[__operator] lifted: !int[n] {
	return __add_SB[n](b, a);
}

def __add_sZ[n:!ℕ](a: int[n], b: !ℤ) @[__operator] lifted: int[n] {
	return qint_iaddc[n](dup(a) as B^n, b) as int[n];
}
def __add_SZ[n:!ℕ](a: !int[n], b: !ℤ) @[__operator] lifted: !int[n] {
	return __add_Z(a as !Z, b) as !int[n];
}
def __add_Zs[n:!ℕ](a: !ℤ, b: int[n]) @[__operator] lifted: int[n] {
	return __add_sZ[n](b, a);
}
def __add_ZS[n:!ℕ](a: !ℤ, b: !int[n]) @[__operator] lifted: !int[n] {
	return __add_Z(a, b as !Z) as !int[n];
}

def __add_u[n:!ℕ](a: uint[n], b: uint[n]) @[__operator] lifted: uint[n] {
	return qint_iaddq[n](dup(a) as B^n, b as B^n) as uint[n];
}
def __add_Uu[n:!ℕ](a: !uint[n], b: uint[n]) @[__operator] lifted: uint[n] {
	return __add_uZ[n](b, a as !Z);
}
def __add_uU[n:!ℕ](a: uint[n], b: !uint[n]) @[__operator] lifted: uint[n] {
	return __add_uZ[n](a, b as !Z);
}
def __add_U[n:!ℕ](a: !uint[n], b: !uint[n]) @[__operator] lifted: !uint[n] {
	return __add_N(a as !N, b as !N) as !uint[n];
}

def __add_ub[n:!ℕ](a: uint[n], b: 𝔹) @[__operator] lifted: uint[n] {
	return __add_u[n](a, qubit_to_uint[n](b));
}
def __add_Ub[n:!ℕ](a: !uint[n], b: 𝔹) @[__operator] lifted: uint[n] {
	if !b {
		return a as uint[n];
	}
	return __add_N(a as !N, 1) as uint[n];
}
def __add_uB[n:!ℕ](a: uint[n], b: !𝔹) @[__operator] lifted: uint[n] {
	if !b {
		return dup(a);
	}
	return __add_uZ[n](a, 1);
}
def __add_UB[n:!ℕ](a: !uint[n], b: !𝔹) @[__operator] lifted: !uint[n] {
	return __add_N(a as !N, b) as !uint[n];
}

def __add_bu[n:!ℕ](a: 𝔹, b: uint[n]) @[__operator] lifted: uint[n] {
	return __add_ub[n](b, a);
}
def __add_Bu[n:!ℕ](a: !𝔹, b: uint[n]) @[__operator] lifted: uint[n] {
	return __add_uB[n](b, a);
}
def __add_bU[n:!ℕ](a: 𝔹, b: !uint[n]) @[__operator] lifted: uint[n] {
	if !a {
		return b as uint[n];
	}
