	}
	return r as int[n];
}
def __mod_SZ[n:!ℕ](a: !int[n], b: !ℤ) @[__operator] lifted: !int[n] {
	return __mod_Z(a as !Z, b) as !int[n];
}
def __mod_Zs[n:!ℕ](a: !ℤ, b: int[n]) @[__operator] lifted: int[n] {
	(a_sign, a1) := int_sign_abs(a);
	(b_sign, b1) := qint_sign_abs[n](b);
	(q, r) := qint_udivmod_cq[n](a1, b1);
	if qint_eqc[n](r, 0) {
		adj := 0;
	} else {
		adj := dup(b_sign);
		if a_sign {
			adj := X(adj);
		}
	}
	if a_sign {
		r := qint_neg[n](r);
	}
	if adj {
		r := qint_iaddq[n](r, b as B^n);
	}
	if qint_eqc[n](r, 0) {
		0 := adj;
	} else {
		if a_sign {
			adj := X(adj);
		}
		dup(b_sign) := adj;
	}
	return r as int[n];
}
def __mod_ZS[n:!ℕ](a: !ℤ, b: !int[n]) @[__operator] lifted: !int[n] {
	return __mod_Z(a, b as !Z) as !int[n];
}

