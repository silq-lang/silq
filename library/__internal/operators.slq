def __neq_uR[n:!ℕ](a: uint[n], b: !ℝ) @[__operator] lifted: 𝔹 {
	return X(__eq_uR[n](a, b));
}
def __neq_Cu[n:!ℕ](a: !ℂ, b: uint[n]) @[__operator] lifted: 𝔹 {
	return X(__eq_Cu[n](a, b));
}
def __neq_uC[n:!ℕ](a: uint[n], b: !ℂ) @[__operator] lifted: 𝔹 {
	return X(__eq_uC[n](a, b));
}

def __neq_NU[n:!ℕ](a: !ℕ, b: !uint[n]) @[__operator] lifted: !𝔹 {
	return __not_B(__eq_NU[n](a, b));
}
def __neq_UN[n:!ℕ](a: !uint[n], b: !ℕ) @[__operator] lifted: !𝔹 {
	return __not_B(__eq_UN[n](a, b));
}
def __neq_ZU[n:!ℕ](a: !ℤ, b: !uint[n]) @[__operator] lifted: !𝔹 {
	return __not_B(__eq_ZU[n](a, b));
}
def __neq_UZ[n:!ℕ](a: !uint[n], b: !ℤ) @[__operator] lifted: !𝔹 {
	return __not_B(__eq_UZ[n](a, b));
}
def __neq_QU[n:!ℕ](a: !ℚ, b: !uint[n]) @[__operator] lifted: !𝔹 {
	return __not_B(__eq_QU[n](a, b));
}
def __neq_UQ[n:!ℕ](a: !uint[n], b: !ℚ) @[__operator] lifted: !𝔹 {
	return __not_B(__eq_UQ[n](a, b));
}
def __neq_RU[n:!ℕ](a: !ℝ, b: !uint[n]) @[__operator] lifted: !𝔹 {
	return __not_B(__eq_RU[n](a, b));
}
def __neq_UR[n:!ℕ](a: !uint[n], b: !ℝ) @[__operator] lifted: !𝔹 {
	return __not_B(__eq_UR[n](a, b));
}
def __neq_CU[n:!ℕ](a: !ℂ, b: !uint[n]) @[__operator] lifted: !𝔹 {
	return __not_B(__eq_CU[n](a, b));
}
def __neq_UC[n:!ℕ](a: !uint[n], b: !ℂ) @[__operator] lifted: !𝔹 {
	return __not_B(__eq_UC[n](a, b));
}

def __neq_N(a: !ℕ, b: !ℕ) @[__operator] lifted: !𝔹 {
	return __not_B(__eq_N(a, b));
}
def __neq_Z(a: !ℤ, b: !ℤ) @[__operator] lifted: !𝔹 {
	return __not_B(__eq_Z(a, b));
}
def __neq_Q(a: !ℚ, b: !ℚ) @[__operator] lifted: !𝔹 {
