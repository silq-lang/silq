// a % b
def __mod_s[n:!ℕ](a: int[n], b: int[n]) @[__operator] lifted: int[n] {
	(a_sign, a1) := qint_sign_abs[n](a);
	(b_sign, b1) := qint_sign_abs[n](b);
	(q, r) := qint_udivmod_qq[n, n](a1, b1);
	if qint_eqc[n](r, 0) {
		adj := 0;
	} else {
		adj := __xorb_b(a_sign, b_sign);
	}
	if a_sign {
		r := qint_neg[n](r);
	}
	if adj {
		r := qint_iaddq[n](r, b as B^n);
	}
	if qint_eqc[n](r, 0) {
		0 := adj;
	} else {
		__xorb_b(a_sign, b_sign) := adj;
	}
	return r as int[n];
}
def __mod_Ss[n:!ℕ](a: !int[n], b: int[n]) @[__operator] lifted: int[n] {
	return __mod_Zs[n](a as !Z, b);
}
def __mod_sS[n:!ℕ](a: int[n], b: !int[n]) @[__operator] lifted: int[n] {
	return __mod_sZ[n](a, b as !Z);
}
def __mod_S[n:!ℕ](a: !int[n], b: !int[n]) @[__operator] lifted: !int[n] {
	return __mod_Z(a as !Z, b as !Z) as !int[n];
}

