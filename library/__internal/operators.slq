def __idiv_Zs[n:!ℕ](a: !ℤ, b: int[n]) @[__operator] lifted: int[n] {
	(a_sign, a1) := int_sign_abs(a);
	(b_sign, b1) := qint_sign_abs[n](b);
	(q, r) := qint_udivmod_cq[n](a1, b1);
	adj := b_sign;
	if a_sign {
		adj := X(adj);
	}
	if adj {
		q := qint_neg[n](q);
	}
	if qint_eqc[n](r, 0) {
		adj = 0;
	}
	if adj {
		q := qint_isubc[n](q, 1);
	}
	return q as int[n];
}
