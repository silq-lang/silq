def __idiv_sZ[n:!ℕ](a: int[n], b: !ℤ) @[__operator] lifted: int[n] {
	(a_sign, a1) := qint_sign_abs[n](a);
	(b_sign, b1) := int_sign_abs(b);
	(q, r) := qint_udivmod_qc[n](a1, b1);
	adj := a_sign;
	if b_sign {
		adj := X(adj);
	}
	if adj {
		q := qint_neg[n](q);
	}
	if qint_eqc[n](r, 0) {
		adj = 0;
	}
	if adj {
		q := qint_isubc[n](q, 1);
	}
	return q as int[n];
}
def __idiv_SZ[n:!ℕ](a: !int[n], b: !ℤ) @[__operator] lifted: !int[n] {
