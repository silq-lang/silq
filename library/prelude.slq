def sign(x:!в„қ)lifted:!в„Ө{
	if x<0{ return -1; }
	if x>0{ return 1; }
	return 0;
}
// TODO: make the following functions generic
def abs(x:!в„қ)lifted:!в„қ вҮ’ if x<0 then -x else x;
def min[n:!в„•](x:!в„қ^n)lifted:!в„қ{
	r:=x[0];
	for i in [1..n){
		if x[i]<r{
			r=x[i];
		}
	}
	return r;
}
def max[n:!в„•](x:!в„қ^n)lifted:!в„қ{
	r:=x[0];
	for i in [1..n){
		if x[i]>r{
			r=x[i];
		}
	}
	return r;
}

def hypot[n:!в„•](x:!в„қ^n) lifted: !в„қ {
	def hypot2(x:!в„қ,y:!в„қ) @[extern="primitive.real.hypot2"] lifted: !в„қ;
	if n=2{ return hypot2(x coerce !в„қ^2); }
	def hypot3(x:!в„қ,y:!в„қ,z:!в„қ) @[extern="primitive.real.hypot3"] lifted: !в„қ;
	if n=3{ return hypot3(x coerce !в„қ^3); }
    m:=0;
    sumsq:=0;
    for i in [0..n){
        v:=x[i];
        ax:=abs(v);
        if axвү 0{
            if ax>m{
                t:=m/ax;
                sumsq=1+sumsqВ·t^2;
                m=ax;
            }else{
                t:=ax/m;
                sumsq=sumsq+t^2;
            }
        }
    }
    if m=0 { return 0; }
    return m*sqrt(sumsq);
}

рқ‘–:=1i;
def cfromri(re:!в„қ,im:!в„қ) @[extern="primitive.complex.cfromri"] qfree: !в„Ӯ;
def ctori(z:!в„Ӯ) @[extern="primitive.complex.ctori"] qfree: !в„қГ—!в„қ;
def creal(z:!в„Ӯ)lifted: !в„қ вҮ’ ctori(z)[0];
def cimag(z:!в„Ӯ)lifted: !в„қ вҮ’ ctori(z)[1];
def conj(z:!в„Ӯ)qfree: !в„Ӯ{
	(re,im):=ctori(z);
	return cfromri(re,-im);
}
def cinv(z:!в„Ӯ)lifted:!в„Ӯ{
	(re,im):=ctori(z);
	denom:=re^2+im^2;
	return cfromri(re/denom,-im/denom);
}

def cabs(z:!в„Ӯ)lifted:!в„қ вҮ’ hypot(ctori(z));
def carg(z:!в„Ӯ)lifted:!в„қ{
	(re,im):=ctori(z);
	return atan2(im,re);
}
def cis(Оё:!в„қ)lifted:!в„Ӯ вҮ’ cfromri(cos(Оё),sin(Оё));
def expi(Оё:!в„қ)lifted:!в„Ӯ вҮ’ cis(Оё);
def cism1(Оё:!в„қ)lifted:!в„Ӯ{
	(c,s):=ctori(cis(Оё/2));
	return cfromri(-2В·s^2,2В·sВ·c);
}
def expim1(Оё:!в„қ)lifted:!в„Ӯ вҮ’ cism1(Оё);
def ctort(z:!в„Ӯ)qfree:!в„қГ—!в„қ{
	(re,im):=ctori(z);
	return (hypot(re,im),atan2(im,re));
}
def cfromrt(r:!в„қ,Оё:!в„қ)qfree:!в„Ӯ вҮ’ rВ·cis(Оё);

/+def csqrt(z:!в„Ӯ)lifted:!в„Ӯ{
	(r,Оё):=ctort(z);
	return cfromrt(sqrt(r),Оё/2);
}+/
def csqrt(z:!в„Ӯ)lifted:!в„Ӯ {
	(x,y):=ctori(z);
	if y=0{
		if xвүҘ0{ return cfromri(sqrt(x),0); }
		else{ return cfromri(0,sqrt(-x)); }
	}
	r:=hypot(x,y);
	if xвүҘ0{
		u:=sqrt((r+x)/2);
		v:=y/(2В·u);
		return cfromri(u,v);
	}else{
		v:=sign(y)В·sqrt((r-x)/2);
		u:=y/(2В·v);
		return cfromri(u,v);
	}
}
def csqrt1pm1(z:!в„Ӯ)lifted:!в„Ӯ{
	if z = 0 { return 0; }
	s := csqrt(1+z);
	if cabs(s-1)<1/2 {
		return z/(s+1);
	} else {
		return s-1;
	}
}
def cexp(z:!в„Ӯ)lifted:!в„Ӯ{
	(re,im):=ctori(z);
	return exp(re)В·cis(im);
}
def cexpm1(z:!в„Ӯ)lifted:!в„Ӯ{
	(re,im):=ctori(z);
	eiy:=cis(im);
	eiy_m1:=cism1(im);
	exm1:=expm1(re);
	return exm1В·eiy+eiy_m1;
}
def cexpi(z:!в„Ӯ)lifted:!в„Ӯ{
	(re,im):=ctori(z);
	return exp(-im)В·cis(re);
}
def cexpim1(z:!в„Ӯ)lifted:!в„Ӯ вҮ’ cexpm1(рқ‘–В·z);
def clog(z:!в„Ӯ)lifted:!в„Ӯ{
	(r,Оё):=ctort(z);
	return cfromri(log(r),Оё);
}
def clog1p(w:!в„Ӯ)lifted:!в„Ӯ{
	(re,im):=ctori(w);
	if abs(re)>1/4||abs(im)>1/4{ return clog(1+w); }
	a:=1+re, t:=2В·re+re^2+im^2;
	return cfromri(log1p(t)/2,atan2(im,a));
}
def cpow(a:!в„Ӯ,b:!в„Ӯ)lifted:!в„Ӯ{
	(u,v):=ctori(b);
	if b=0 { return 1; }
	if a=0{
		assert(uвүҘ0);
		assert(v=0);
		if u>0{ return 0; }
	}
	if v=0вҲ§inв„Ө(u){
		return a^(u coerce !в„Ө);
	}
	(r,Оё):=ctort(a);
	ln_r:=log(r);
	return exp(uВ·ln_r-vВ·Оё)В·cis(vВ·ln_r+uВ·Оё);
}
def csin(z:!в„Ӯ)lifted:!в„Ӯ{
	(re,im):=ctori(z);
	return cfromri(sin(re)В·cosh(im),cos(re)В·sinh(im));
}
def casin(z:!в„Ӯ)lifted:!в„Ӯ вҮ’ clog(рқ‘–В·z+csqrt((1-z)В·(1+z)))/рқ‘–;
def ccos(z:!в„Ӯ)lifted:!в„Ӯ{
	(re,im):=ctori(z);
	return cfromri(cos(re)В·cosh(im),-sin(re)В·sinh(im));
}
def cacos(z:!в„Ӯ)lifted:!в„Ӯ вҮ’ clog(z+рқ‘–В·csqrt((1-z)В·(1+z)))/рқ‘–;
//def ctan(z:!в„Ӯ)lifted:!в„Ӯ вҮ’ csin(z)/ccos(z);
def ctan(z:!в„Ӯ)lifted:!в„Ӯ{
	(re,im):=ctori(z);
	num_re:=sin(2В·re);
	num_im:=sinh(2В·im);
	den:=cos(2В·re)+cosh(2В·im);
	return cfromri(num_re/den,num_im/den);
}
def catan(z:!в„Ӯ)lifted:!в„Ӯ вҮ’ рқ‘–/2В·(clog1p(-рқ‘–В·z)-clog1p(рқ‘–В·z));

def csinh(z:!в„Ӯ)lifted:!в„Ӯ вҮ’ (cexpm1(z)-cexpm1(-z))/2;
def casinh(z:!в„Ӯ)lifted:!в„Ӯ вҮ’ clog1p(z+csqrt1pm1(z^2));
def ccosh(z:!в„Ӯ)lifted:!в„Ӯ вҮ’ (cexpm1(z)+cexpm1(-z))/2;
def cacosh(z:!в„Ӯ)lifted:!в„Ӯ вҮ’ clog1p((z-1)+csqrt(z-1)В·csqrt(z+1));
//def ctanh(z:!в„Ӯ)lifted:!в„Ӯ вҮ’ csinh(z)/ccosh(z);
def ctanh(z:!в„Ӯ)lifted:!в„Ӯ{
	(re,im):=ctori(z);
	num_re:=sinh(2В·re);
	num_im:=sin(2В·im);
	den:=cosh(2В·re)+cos(2В·im);
	return cfromri(num_re/den,num_im/den);
}
def catanh(z:!в„Ӯ)lifted:!в„Ӯ вҮ’ (clog1p(z)-clog1p(-z))/2;

def array[П„:*](n: !в„•,const x:П„) @[artificial] lifted: П„[]вҮ’vector[П„](n, x);
def vector[П„:*](n:!в„•,const x:П„) @[artificial] lifted: П„^n {
	def impl[П„](n: !в„•, const x: П„) @[extern="primitive.vector"] lifted: П„^n; // TODO: make unnecessary
	return impl[П„](n, x);
}

def print[П„:*](x:!П„) @[artificial] lifted: рқҹҷ {
	def impl[П„': ctype](x: П„') @[extern="primitive.print"] lifted: рқҹҷ; // TODO: make unnecessary
	impl[!П„](x);
}
def dump() @[extern="primitive.dump"] lifted: рқҹҷ;
def exit() @[extern="primitive.exit"] lifted: вҠҘ;

