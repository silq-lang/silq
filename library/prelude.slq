// first-class inference
dat Distribution[a]{ } // TODO: dat Distribution[a];
def infer[a](f:рқҹҷвҶ’ a):Distribution[a] вҮ’ sampleFrom("(r;f)=>Оҙ(Оӣx.f()[x]/вҲ«dy f()[y])[r]",f):Distribution[a];
def errorPr[a](d:Distribution[a]):в„қ вҮ’ 0;
def sample[a](d:Distribution[a]):a вҮ’ sampleFrom("(x;d)=>d[x]",d):a;
def expectation(d:Distribution[в„қ]):в„қ вҮ’ (sampleFrom("(r;d)=>Оҙ(0)[-r+вҲ«dx d[x]В·x]",d):в„қ);

// distributions
def gauss(Ој:в„қ,ОҪ:в„қ):в„қ вҮ’ sampleFrom("(x;Ој,ОҪ)=>[ОҪ=0]В·Оҙ(0)[-Ој+x]+[ОҪвү 0]В·e^((-1/2В·xВІ+-1/2В·ОјВІ+xВ·Ој)В·в…ҹОҪ)В·в…ҹвҲҡ2М…В·в…ҹвҲҡОҪМ…В·в…ҹвҲҡПҖМ…",Ој,ОҪ);
def Gauss(Ој:в„қ,ОҪ:в„қ):Distribution[в„қ] вҮ’ infer(()=>(sampleFrom("(x;Ој,ОҪ)=>[ОҪ=0]В·Оҙ(0)[-Ој+x]+[ОҪвү 0]В·e^((-1/2В·xВІ+-1/2В·ОјВІ+xВ·Ој)В·в…ҹОҪ)В·в…ҹвҲҡ2М…В·в…ҹвҲҡОҪМ…В·в…ҹвҲҡПҖМ…",Ој,ОҪ):в„қ));

def chiSquared(k:в„қ):в„қ вҮ’ sampleFrom("(x;k)=>[-xвүӨ0]В·[kвү 0]В·x^(-1+1/2В·k)В·в…ҹ(вҲ«dОҫвӮҒ[-ОҫвӮҒвүӨ0]В·ОҫвӮҒ^(-1+1/2В·k)В·в…ҹe^ОҫвӮҒ)В·в…ҹ2^(1/2В·k)В·в…ҹe^(1/2В·x)+[k=0]В·Оҙ(0)[x]",k):в„қ;
def ChiSquared(k:в„қ):Distribution[в„қ] вҮ’ infer(() вҮ’ sampleFrom("(x;k)=>[-xвүӨ0]В·[kвү 0]В·x^(-1+1/2В·k)В·в…ҹ(вҲ«dОҫвӮҒ[-ОҫвӮҒвүӨ0]В·ОҫвӮҒ^(-1+1/2В·k)В·в…ҹe^ОҫвӮҒ)В·в…ҹ2^(1/2В·k)В·в…ҹe^(1/2В·x)+[k=0]В·Оҙ(0)[x]",k):в„қ);

def rayleigh(ОҪ:в„қ):в„қ вҮ’ sampleFrom("(x;ОҪ)=>[-xвүӨ0]В·[ОҪвү 0]В·xВ·в…ҹe^(1/2В·xВІВ·в…ҹОҪ)В·в…ҹОҪ+[ОҪ=0]В·Оҙ(0)[x]",ОҪ):в„қ;
def Rayleigh(ОҪ:в„қ):Distribution[в„қ] вҮ’	infer(() вҮ’ sampleFrom("(x;ОҪ)=>[-xвүӨ0]В·[ОҪвү 0]В·xВ·в…ҹe^(1/2В·xВІВ·в…ҹОҪ)В·в…ҹОҪ+[ОҪ=0]В·Оҙ(0)[x]",ОҪ):в„қ);

def truncatedGauss(Ој:в„қ,ОҪ:в„қ,a:в„қ,b:в„қ):в„қ вҮ’ sampleFrom("(x;Ој,ОҪ,a,b)=>[-b+xвүӨ0]В·[-x+aвүӨ0]В·[ОҪвү 0]В·e^((-1/2В·xВІ+-1/2В·ОјВІ+xВ·Ој)В·в…ҹОҪ)В·в…ҹ((d/dx)вҒ»В№[e^(-xВІ)]((-Ој+b)В·в…ҹвҲҡОҪМ…)+-(d/dx)вҒ»В№[e^(-xВІ)]((-Ој+a)В·в…ҹвҲҡОҪМ…))В·в…ҹОҪВ·в…ҹвҲҡ2М…В·в…ҹвҲҡПҖМ…+[ОҪ=0]В·Оҙ(0)[-Ој+x]",Ој,ОҪ,a,b):в„қ;
def TruncatedGauss(Ој:в„қ,ОҪ:в„қ,a:в„қ,b:в„қ):Distribution[в„қ] вҮ’ infer(() вҮ’ sampleFrom("(x;Ој,ОҪ,a,b)=>[-b+xвүӨ0]В·[-x+aвүӨ0]В·[ОҪвү 0]В·e^((-1/2В·xВІ+-1/2В·ОјВІ+xВ·Ој)В·в…ҹОҪ)В·в…ҹ((d/dx)вҒ»В№[e^(-xВІ)]((-Ој+b)В·в…ҹвҲҡОҪМ…)+-(d/dx)вҒ»В№[e^(-xВІ)]((-Ој+a)В·в…ҹвҲҡОҪМ…))В·в…ҹОҪВ·в…ҹвҲҡ2М…В·в…ҹвҲҡПҖМ…+[ОҪ=0]В·Оҙ(0)[-Ој+x]",Ој,ОҪ,a,b):в„қ);

def pareto(a:в„қ,b:в„қ):в„қ вҮ’ sampleFrom("(x;a,b)=>[-x+bвүӨ0]В·[-xвүӨ0]В·aВ·b^aВ·x^(-1+-a)",a,b):в„қ;
def Pareto(a:в„қ,b:в„қ):Distribution[в„қ] вҮ’ infer(()=>sampleFrom("(x;a,b)=>[-x+bвүӨ0]В·[-xвүӨ0]В·aВ·b^aВ·x^(-1+-a)",a,b):в„қ);

def uniform(a:в„қ,b:в„қ):в„қ вҮ’ sampleFrom("(x;a,b)=>[aвү b]В·[aвүӨx]В·[xвүӨb]В·в…ҹ(b-a)+[a=b]В·Оҙ(0)[a-x]",a,b):в„қ;
def Uniform(a:в„қ,b:в„қ):Distribution[в„қ] вҮ’ infer(() вҮ’ sampleFrom("(x;a,b)=>[aвү b]В·[aвүӨx]В·[xвүӨb]В·в…ҹ(b-a)+[a=b]В·Оҙ(0)[a-x]",a,b):в„қ);

/+def cosUniform() вҮ’ sampleFrom("(r)=>[-1+-rвү 0]В·[-1+-rвүӨ0]В·[-1+rвүӨ0]В·[-r+1вү 0]В·в…ҹПҖВ·в…ҹвҲҡ-М…rМ…ВІМ…+М…1М…");
def CosUniform() вҮ’ infer(() вҮ’ sampleFrom("(r)=>[-1+-rвү 0]В·[-1+-rвүӨ0]В·[-1+rвүӨ0]В·[-r+1вү 0]В·в…ҹПҖВ·в…ҹвҲҡ-М…rМ…ВІМ…+М…1М…"));+/

def flip(p:в„қ):в„қ вҮ’ sampleFrom("(x;p)=>(1-p)В·Оҙ(0)[x]+pВ·Оҙ(0)[1-x]",p):в„қ;
def Flip(p:в„қ):Distribution[в„қ] вҮ’ infer(()=>sampleFrom("(x;p)=>(1-p)В·Оҙ(0)[x]+pВ·Оҙ(0)[1-x]",p):в„қ);
def bernoulli(p:в„қ) вҮ’ flip(p);
def Bernoulli(p:в„қ) вҮ’ Flip(p);

def uniformInt(a:в„қ,b:в„қ):в„қ вҮ’ sampleFrom("(x;a,b)=>(вҲ‘_i[aвүӨi]В·[iвүӨb]В·Оҙ(0)[i-x])В·в…ҹ(вҲ‘_i[aвүӨi]В·[iвүӨb])",a,b):в„қ;
def UniformInt(a:в„қ,b:в„қ):Distribution[в„қ] вҮ’ infer(() вҮ’ sampleFrom("(x;a,b)=>(вҲ‘_i[aвүӨi]В·[iвүӨb]В·Оҙ(0)[i-x])В·в…ҹ(вҲ‘_i[aвүӨi]В·[iвүӨb])",a,b):в„қ);

def binomial(n:в„қ,p:в„қ):в„қ вҮ’ sampleFrom("(x;n,p)=>вҲ‘_ОҫвӮҒ(-p+1)^(-ОҫвӮҒ+n)В·(вҲ«dОҫвӮӮ[-ОҫвӮӮвүӨ0]В·ОҫвӮӮ^nВ·в…ҹe^ОҫвӮӮ)В·[-n+ОҫвӮҒвүӨ0]В·[-ОҫвӮҒвүӨ0]В·p^ОҫвӮҒВ·Оҙ(0)[-ОҫвӮҒ+x]В·в…ҹ(вҲ«dОҫвӮӮ[-ОҫвӮӮвүӨ0]В·ОҫвӮӮ^(-ОҫвӮҒ+n)В·в…ҹe^ОҫвӮӮ)В·в…ҹ(вҲ«dОҫвӮӮ[-ОҫвӮӮвүӨ0]В·ОҫвӮӮ^ОҫвӮҒВ·в…ҹe^ОҫвӮӮ)",n,p):в„қ;
def Binomial(n:в„қ,p:в„қ):Distribution[в„қ] вҮ’ infer(() вҮ’ sampleFrom("(x;n,p)=>вҲ‘_ОҫвӮҒ(-p+1)^(-ОҫвӮҒ+n)В·(вҲ«dОҫвӮӮ[-ОҫвӮӮвүӨ0]В·ОҫвӮӮ^nВ·в…ҹe^ОҫвӮӮ)В·[-n+ОҫвӮҒвүӨ0]В·[-ОҫвӮҒвүӨ0]В·p^ОҫвӮҒВ·Оҙ(0)[-ОҫвӮҒ+x]В·в…ҹ(вҲ«dОҫвӮӮ[-ОҫвӮӮвүӨ0]В·ОҫвӮӮ^(-ОҫвӮҒ+n)В·в…ҹe^ОҫвӮӮ)В·в…ҹ(вҲ«dОҫвӮӮ[-ОҫвӮӮвүӨ0]В·ОҫвӮӮ^ОҫвӮҒВ·в…ҹe^ОҫвӮӮ)",n,p):в„қ);

def negBinomial(r:в„қ,p:в„қ):в„қ вҮ’ sampleFrom("(x;r,p)=>вҲ‘_ОҫвӮҒ(-p+1)^ОҫвӮҒВ·(вҲ«dОҫвӮӮ[-ОҫвӮӮвүӨ0]В·ОҫвӮӮ^(-1+r+ОҫвӮҒ)В·в…ҹe^ОҫвӮӮ)В·[-ОҫвӮҒвүӨ0]В·p^rВ·Оҙ(0)[-ОҫвӮҒ+x]В·в…ҹ(вҲ«dОҫвӮӮ[-ОҫвӮӮвүӨ0]В·ОҫвӮӮ^(-1+r)В·в…ҹe^ОҫвӮӮ)В·в…ҹ(вҲ«dОҫвӮӮ[-ОҫвӮӮвүӨ0]В·ОҫвӮӮ^ОҫвӮҒВ·в…ҹe^ОҫвӮӮ)",r,p):в„қ;
def NegBinomial(r:в„қ,p:в„қ):Distribution[в„қ] вҮ’ infer(() вҮ’ sampleFrom("(x;r,p)=>вҲ‘_ОҫвӮҒ(-p+1)^ОҫвӮҒВ·(вҲ«dОҫвӮӮ[-ОҫвӮӮвүӨ0]В·ОҫвӮӮ^(-1+r+ОҫвӮҒ)В·в…ҹe^ОҫвӮӮ)В·[-ОҫвӮҒвүӨ0]В·p^rВ·Оҙ(0)[-ОҫвӮҒ+x]В·в…ҹ(вҲ«dОҫвӮӮ[-ОҫвӮӮвүӨ0]В·ОҫвӮӮ^(-1+r)В·в…ҹe^ОҫвӮӮ)В·в…ҹ(вҲ«dОҫвӮӮ[-ОҫвӮӮвүӨ0]В·ОҫвӮӮ^ОҫвӮҒВ·в…ҹe^ОҫвӮӮ)",r,p):в„қ);

def geometric(p:в„қ):в„қ вҮ’ sampleFrom("(x;p)=>вҲ‘_i[0вүӨi]В·(1-p)^iВ·pВ·Оҙ(0)[i-x]",p);
def Geometric(p:в„қ):Distribution[в„қ] вҮ’ infer(() вҮ’ sampleFrom("(x;p)=>вҲ‘_i[0вүӨi]В·(1-p)^iВ·pВ·Оҙ(0)[i-x]",p));

def poisson(О»:в„қ):в„қ вҮ’ sampleFrom("(x;l)=>(вҲ‘_ОҫвӮҒ[-ОҫвӮҒвүӨ0]В·Оҙ(0)[-ОҫвӮҒ+x]В·l^ОҫвӮҒВ·в…ҹ(вҲ«dОҫвӮӮ[-ОҫвӮӮвүӨ0]В·ОҫвӮӮ^ОҫвӮҒВ·в…ҹe^ОҫвӮӮ))В·в…ҹe^l",О»);
def Poisson(О»:в„қ):Distribution[в„қ] вҮ’ infer(() вҮ’ sampleFrom("(x;l)=>(вҲ‘_ОҫвӮҒ[-ОҫвӮҒвүӨ0]В·Оҙ(0)[-ОҫвӮҒ+x]В·l^ОҫвӮҒВ·в…ҹ(вҲ«dОҫвӮӮ[-ОҫвӮӮвүӨ0]В·ОҫвӮӮ^ОҫвӮҒВ·в…ҹe^ОҫвӮӮ))В·в…ҹe^l",О»));

def beta(Оұ:в„қ,ОІ:в„қ):в„қ вҮ’ sampleFrom("(x;Оұ,ОІ)=>((-x+1)^(-1+ОІ)В·[-1+xвүӨ0]В·[-xвүӨ0]В·[Оұвү 0]В·[ОІвү 0]В·x^(-1+Оұ)+[Оұ=0]В·Оҙ(0)[x]+[ОІ=0]В·Оҙ(0)[-x+1])В·(1/2В·[Оұ=0]В·[ОІ=0]+[Оұ=0]В·[ОІвү 0]+[Оұвү 0]В·[ОІ=0]+[Оұвү 0]В·[ОІвү 0]В·в…ҹ(вҲ«dОҫвӮҒ(-ОҫвӮҒ+1)^(-1+ОІ)В·[-1+ОҫвӮҒвүӨ0]В·[-ОҫвӮҒвүӨ0]В·ОҫвӮҒ^(-1+Оұ)))",Оұ,ОІ):в„қ;
def Beta(Оұ:в„қ,ОІ:в„қ):Distribution[в„қ] вҮ’ infer(()=>sampleFrom("(x;Оұ,ОІ)=>((-x+1)^(-1+ОІ)В·[-1+xвүӨ0]В·[-xвүӨ0]В·[Оұвү 0]В·[ОІвү 0]В·x^(-1+Оұ)+[Оұ=0]В·Оҙ(0)[x]+[ОІ=0]В·Оҙ(0)[-x+1])В·(1/2В·[Оұ=0]В·[ОІ=0]+[Оұ=0]В·[ОІвү 0]+[Оұвү 0]В·[ОІ=0]+[Оұвү 0]В·[ОІвү 0]В·в…ҹ(вҲ«dОҫвӮҒ(-ОҫвӮҒ+1)^(-1+ОІ)В·[-1+ОҫвӮҒвүӨ0]В·[-ОҫвӮҒвүӨ0]В·ОҫвӮҒ^(-1+Оұ)))",Оұ,ОІ):в„қ);

def gamma(Оұ:в„қ,ОІ:в„қ):в„қ вҮ’ sampleFrom("(x;Оұ,ОІ)=>([-xвүӨ0]В·[Оұвү 0]В·x^(-1+Оұ)В·в…ҹe^(xВ·ОІ)+[Оұ=0]В·Оҙ(0)[x])В·([Оұ=0]+[Оұвү 0]В·в…ҹ(вҲ«dОҫвӮҒ[-ОҫвӮҒвүӨ0]В·ОҫвӮҒ^(-1+Оұ)В·в…ҹe^(ОІВ·ОҫвӮҒ)))",Оұ,ОІ):в„қ;
def Gamma(Оұ:в„қ,ОІ:в„қ):Distribution[в„қ] вҮ’ infer(() вҮ’ sampleFrom("(x;Оұ,ОІ)=>([-xвүӨ0]В·[Оұвү 0]В·x^(-1+Оұ)В·в…ҹe^(xВ·ОІ)+[Оұ=0]В·Оҙ(0)[x])В·([Оұ=0]+[Оұвү 0]В·в…ҹ(вҲ«dОҫвӮҒ[-ОҫвӮҒвүӨ0]В·ОҫвӮҒ^(-1+Оұ)В·в…ҹe^(ОІВ·ОҫвӮҒ)))",Оұ,ОІ):в„қ);

def laplace(Ој:в„қ,b:в„қ):в„қ вҮ’ sampleFrom("(x;Ој,b)=>(1/2В·[-x+ОјвүӨ0]В·e^((-x+Ој)В·в…ҹb)+1/2В·[-Ој+xвү 0]В·[-Ој+xвүӨ0]В·e^((-Ој+x)В·в…ҹb))В·[bвү 0]В·в…ҹb+[b=0]В·Оҙ(0)[-Ој+x]",Ој,b):в„қ;
def Laplace(Ој:в„қ,b:в„қ):Distribution[в„қ] вҮ’ infer(() вҮ’ sampleFrom("(x;Ој,b)=>(1/2В·[-x+ОјвүӨ0]В·e^((-x+Ој)В·в…ҹb)+1/2В·[-Ој+xвү 0]В·[-Ој+xвүӨ0]В·e^((-Ој+x)В·в…ҹb))В·[bвү 0]В·в…ҹb+[b=0]В·Оҙ(0)[-Ој+x]",Ој,b):в„қ);

def cauchy(xвӮҖ:в„қ,Оі:в„қ):в„қ вҮ’ sampleFrom("(x;xвӮҖ,Оі)=>[Оі=0]В·Оҙ(0)[-xвӮҖ+x]+[Оівү 0]В·в…ҹ((-2В·xВ·xвӮҖВ·ПҖ+xвӮҖВІВ·ПҖ+xВІВ·ПҖ)В·в…ҹОіВІ+ПҖ)В·в…ҹОі",xвӮҖ,Оі):в„қ;
def Cauchy(xвӮҖ:в„қ,Оі:в„қ):Distribution[в„қ] вҮ’ infer(() вҮ’ sampleFrom("(x;xвӮҖ,Оі)=>[Оі=0]В·Оҙ(0)[-xвӮҖ+x]+[Оівү 0]В·в…ҹ((-2В·xВ·xвӮҖВ·ПҖ+xвӮҖВІВ·ПҖ+xВІВ·ПҖ)В·в…ҹОіВІ+ПҖ)В·в…ҹОі",xвӮҖ,Оі):в„қ);

def exponential(О»:в„қ):в„қ вҮ’ sampleFrom("(x;l)=>[0вүӨx]В·lВ·e^(-xВ·l)",О»):в„қ;
def Exponential(О»:в„қ):Distribution[в„қ] вҮ’ infer(() вҮ’ sampleFrom("(x;l)=>[0вүӨx]В·lВ·e^(-xВ·l)",О»):в„қ);

def studentT(ОҪ:в„қ):в„қ вҮ’ sampleFrom("(x;ОҪ)=>[ОҪвү 0]В·(1+xВІВ·в…ҹОҪ)^(-1/2+-1/2В·ОҪ)В·в…ҹ(вҲ«dОҫвӮҒ(1+ОҫвӮҒВІВ·в…ҹОҪ)^(-1/2+-1/2В·ОҪ))+[ОҪ=0]В·Оҙ(0)[x]",ОҪ):в„қ;
def StudentT(ОҪ:в„қ):Distribution[в„қ] вҮ’ infer(() вҮ’ sampleFrom("(x;ОҪ)=>[ОҪвү 0]В·(1+xВІВ·в…ҹОҪ)^(-1/2+-1/2В·ОҪ)В·в…ҹ(вҲ«dОҫвӮҒ(1+ОҫвӮҒВІВ·в…ҹОҪ)^(-1/2+-1/2В·ОҪ))+[ОҪ=0]В·Оҙ(0)[x]",ОҪ):в„қ);

def weibull(О»:в„қ,k:в„қ):в„қ вҮ’ sampleFrom("(x;l,k)=>([k=0]В·[lвү 0]+[l=0])В·Оҙ(0)[x]+[-xвүӨ0]В·[kвү 0]В·[lвү 0]В·kВ·x^(-1+k)В·в…ҹe^(x^kВ·в…ҹl^k)В·в…ҹl^k",О»,k):в„қ;
def Weibull(О»:в„қ,k:в„қ):Distribution[в„қ] вҮ’ infer(() вҮ’ sampleFrom("(x;l,k)=>([k=0]В·[lвү 0]+[l=0])В·Оҙ(0)[x]+[-xвүӨ0]В·[kвү 0]В·[lвү 0]В·kВ·x^(-1+k)В·в…ҹe^(x^kВ·в…ҹl^k)В·в…ҹl^k",О»,k):в„қ);

def categorical(p:в„қ[]):в„қ вҮ’ sampleFrom("(x;p)=>вҲ‘_i[0вүӨi]В·[i<p.length]В·p@[i]В·Оҙ(0)[i-x]",p):в„қ;
def Categorical(p:в„қ[]):Distribution[в„қ] вҮ’ infer(() вҮ’ sampleFrom("(x;p)=>вҲ‘_i[0вүӨi]В·[i<p.length]В·p@[i]В·Оҙ(0)[i-x]",p):в„қ);

def dirac[a](x:a) вҮ’ x;
def Dirac[a](x:a) вҮ’ infer(()=>x);

def dirichlet(Оұ: в„қ[]){
	r:=array(Оұ.length,0.0);
	sum:=0.0;
	for i in [0..Оұ.length){
		r[i]=gamma(Оұ[i],1.0);
		sum+=r[i];
	}
	for i in [0..Оұ.length){
		r[i]/=sum;
	}
	return r;
}
def Dirichlet(Оұ: в„қ[]) вҮ’ infer(()=>dirichlet(Оұ));

def multiGauss(Ој: в„қ[], ОЈ: в„қ[][]){
	def mmv(A: в„қ[][], b: в„қ[]){
		r:=array(A.length,0.0);
		for i in [0..A.length){
			for j in [0..b.length){
				r[i]+=A[i][j]*b[j];
			}
		}
		return r;
	}
	def avv(a: в„қ[], b: в„қ[]){
		r:=array(a.length,0.0);
		for i in [0..a.length){
			r[i]=a[i]+b[i];
		}
		return r;
	}
	def dot(a: в„қ[], b: в„қ[]){
		r:=0.0;
		for i in [0..a.length){
			r+=a[i]*b[i];
		}
		return r;
	}
	def cholesky(A: в„қ[][]){
		L := array(A.length,array(A.length,0.0));
		for i in [0..A.length){
			for j in [0..i]{
				t := dot(L[i][0..j],L[j][0..j]);
				if i == j {
					L[i][j] = (A[i][j]-t)^(1/2)
				}else if L[j][j]!=0{
					L[i][j] = (A[i][j]-t)/L[j][j];
				}
			}
		}
		return L;
	}
	r := array(Ој.length,0.0);
	for i in [0..r.length){
		r[i] = gauss(0,1);
	}
	return avv(mmv(cholesky(ОЈ),r),Ој);
}
def MultiGauss(Ој: в„қ[], ОЈ: в„қ[][])вҮ’infer(()вҮ’ multiGauss(Ој,ОЈ));
+/
__NOCHECK__ := 1;
