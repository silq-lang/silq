def inв„Ө(x:!в„қ) @[artificial] lifted:!рқ”№ вҮ’ x==floor(x);
def sqrt(x:!в„қ) @[extern="primitive.real.sqrt"] lifted: !в„қ;
def cbrt(x:!в„қ) @[extern="primitive.real.cbrt"] lifted: !в„қ;
