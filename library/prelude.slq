def atan(x:!ℝ) @[extern="primitive.real.atan"] lifted: !ℝ;
def atan2(y:!ℝ,x:!ℝ) @[extern="primitive.real.atan2"] lifted: !ℝ;
def sinh(x:!ℝ) @[extern="primitive.real.sinh"] lifted: !ℝ;
def asinh(x:!ℝ) @[extern="primitive.real.asinh"] lifted: !ℝ;
def cosh(x:!ℝ) @[extern="primitive.real.cosh"] lifted: !ℝ;
def acosh(x:!ℝ) @[extern="primitive.real.acosh"] lifted: !ℝ;
def tanh(x:!ℝ) @[extern="primitive.real.tanh"] lifted: !ℝ;
def atanh(x:!ℝ) @[extern="primitive.real.atanh"] lifted: !ℝ;
