// prelude file implicitly imported into all silq programs

def dup[П„:*](const x: П„) @[artificial] qfree: П„ {
	def impl[П„](const x: П„) @[extern="primitive.dup"] qfree: П„;
	return impl[П„](x);
}
def measure[П„](x: П„) @[artificial] wild {
	def impl[П„](x: П„) @[extern="primitive.M"] wild: !П„;
	return impl[П„](x);
}
def H(x: рқ”№) @[extern="primitive.H"] mfree: рқ”№;
def X(x: рқ”№) @[extern="primitive.X"] qfree: рқ”№;
def Y(x: рқ”№) @[extern="primitive.Y"] mfree: рқ”№;
def Z(x: рқ”№) @[extern="primitive.Z"] mfree: рқ”№;
def phase(const ПҶ: !в„қ) @[extern="primitive.P"] mfree: рқҹҷ;
def rotX(ПҶ: !в„қ, x: рқ”№) @[extern="primitive.rX"] mfree: рқ”№;
def rotY(ПҶ: !в„қ, x: рқ”№) @[extern="primitive.rY"] mfree: рқ”№;
def rotZ(ПҶ: !в„қ, x: рқ”№) @[artificial] mfree: рқ”№ {
	def impl(const ПҶ: !в„қ, const x: рқ”№) @[extern="primitive.rZ"] mfree: рқҹҷ;
	impl(ПҶ, x);
	return x;
}

def I(x:рқ”№) @[artificial] qfree вҮ’ x;
def S(x:рқ”№) @[artificial] mfree{
	if x { phase(ПҖ/2); }
	return x;
}
def CNOT(const x:рқ”№,y:рқ”№) @[artificial] qfree{
	yвҠ•=x;
	return y;
}
def reverse[П„:*,ПҮ:qtype,ПҶ:*](const f: const П„Г—ПҮ вҶ’mfree ПҶ)(const c: П„, x:ПҶ) @artificial mfree: ПҮ{
	f(c,y):=x;
	return y;
}
def __reverse_qfree[П„:*,ПҮ:qtype,ПҶ:*](const f: const П„Г—ПҮ вҶ’qfree ПҶ)(const c: П„, x:ПҶ) @artificial qfree: ПҮ{ // TODO: use attribute polymorphism instead
	f(c,y):=x;
	return y;
}

