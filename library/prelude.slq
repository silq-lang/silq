def sign(x:!ℝ)lifted:!ℤ{
	if x<0{ return -1; }
	if x>0{ return 1; }
	return 0;
}
// TODO: make the following functions generic
def abs(x:!ℝ)lifted:!ℝ ⇒ if x<0 then -x else x;
def min[n:!ℕ](x:!ℝ^n)lifted:!ℝ{
	r:=x[0];
	for i in [1..n){
		if x[i]<r{
			r=x[i];
		}
	}
	return r;
}
def max[n:!ℕ](x:!ℝ^n)lifted:!ℝ{
	r:=x[0];
	for i in [1..n){
		if x[i]>r{
			r=x[i];
		}
	}
	return r;
}

def hypot[n:!ℕ](x:!ℝ^n) lifted: !ℝ {
	def hypot2(x:!ℝ,y:!ℝ) @[extern="primitive.real.hypot2"] lifted: !ℝ;
	if n=2{ return hypot2(x coerce !ℝ^2); }
	def hypot3(x:!ℝ,y:!ℝ,z:!ℝ) @[extern="primitive.real.hypot3"] lifted: !ℝ;
	if n=3{ return hypot3(x coerce !ℝ^3); }
    m:=0;
    sumsq:=0;
    for i in [0..n){
        v:=x[i];
        ax:=abs(v);
        if ax≠0{
            if ax>m{
                t:=m/ax;
                sumsq=1+sumsq·t^2;
                m=ax;
            }else{
                t:=ax/m;
                sumsq=sumsq+t^2;
            }
        }
    }
    if m=0 { return 0; }
    return m*sqrt(sumsq);
}

𝑖:=1i;
def cfromri(re:!ℝ,im:!ℝ) @[extern="primitive.complex.cfromri"] qfree: !ℂ;
def ctori(z:!ℂ) @[extern="primitive.complex.ctori"] qfree: !ℝ×!ℝ;
def creal(z:!ℂ)lifted: !ℝ ⇒ ctori(z)[0];
def cimag(z:!ℂ)lifted: !ℝ ⇒ ctori(z)[1];
def conj(z:!ℂ)qfree: !ℂ{
	(re,im):=ctori(z);
	return cfromri(re,-im);
}
def cinv(z:!ℂ)lifted:!ℂ{
	(re,im):=ctori(z);
	denom:=re^2+im^2;
	return cfromri(re/denom,-im/denom);
}

def cabs(z:!ℂ)lifted:!ℝ ⇒ hypot(ctori(z));
def carg(z:!ℂ)lifted:!ℝ{
	(re,im):=ctori(z);
	return atan2(im,re);
}
def cis(θ:!ℝ)lifted:!ℂ ⇒ cfromri(cos(θ),sin(θ));
def expi(θ:!ℝ)lifted:!ℂ ⇒ cis(θ);
def cism1(θ:!ℝ)lifted:!ℂ{
	(c,s):=ctori(cis(θ/2));
	return cfromri(-2·s^2,2·s·c);
}
def expim1(θ:!ℝ)lifted:!ℂ ⇒ cism1(θ);
def ctort(z:!ℂ)qfree:!ℝ×!ℝ{
	(re,im):=ctori(z);
	return (hypot(re,im),atan2(im,re));
}
def cfromrt(r:!ℝ,θ:!ℝ)qfree:!ℂ ⇒ r·cis(θ);

/+def csqrt(z:!ℂ)lifted:!ℂ{
	(r,θ):=ctort(z);
	return cfromrt(sqrt(r),θ/2);
}+/
def csqrt(z:!ℂ)lifted:!ℂ {
	(x,y):=ctori(z);
	if y=0{
		if x≥0{ return cfromri(sqrt(x),0); }
		else{ return cfromri(0,sqrt(-x)); }
	}
	r:=hypot(x,y);
	if x≥0{
		u:=sqrt((r+x)/2);
		v:=y/(2·u);
		return cfromri(u,v);
	}else{
		v:=sign(y)·sqrt((r-x)/2);
		u:=y/(2·v);
		return cfromri(u,v);
	}
}
def csqrt1pm1(z:!ℂ)lifted:!ℂ{
	if z = 0 { return 0; }
	s := csqrt(1+z);
	if cabs(s-1)<1/2 {
		return z/(s+1);
	} else {
		return s-1;
	}
}
def cexp(z:!ℂ)lifted:!ℂ{
	(re,im):=ctori(z);
	return exp(re)·cis(im);
}
def cexpm1(z:!ℂ)lifted:!ℂ{
	(re,im):=ctori(z);
	eiy:=cis(im);
	eiy_m1:=cism1(im);
	exm1:=expm1(re);
	return exm1·eiy+eiy_m1;
}
def cexpi(z:!ℂ)lifted:!ℂ{
	(re,im):=ctori(z);
	return exp(-im)·cis(re);
}
def cexpim1(z:!ℂ)lifted:!ℂ ⇒ cexpm1(𝑖·z);
def clog(z:!ℂ)lifted:!ℂ{
	(r,θ):=ctort(z);
	return cfromri(log(r),θ);
}
def clog1p(w:!ℂ)lifted:!ℂ{
	(re,im):=ctori(w);
	if abs(re)>1/4||abs(im)>1/4{ return clog(1+w); }
	a:=1+re, t:=2·re+re^2+im^2;
	return cfromri(log1p(t)/2,atan2(im,a));
}
def cpow(a:!ℂ,b:!ℂ)lifted:!ℂ{
	(u,v):=ctori(b);
	if b=0 { return 1; }
	if a=0{
		assert(u≥0);
		assert(v=0);
		if u>0{ return 0; }
	}
	if v=0∧inℤ(u){
		return a^(u coerce !ℤ);
	}
	(r,θ):=ctort(a);
	ln_r:=log(r);
	return exp(u·ln_r-v·θ)·cis(v·ln_r+u·θ);
}
def csin(z:!ℂ)lifted:!ℂ{
	(re,im):=ctori(z);
	return cfromri(sin(re)·cosh(im),cos(re)·sinh(im));
}
def casin(z:!ℂ)lifted:!ℂ ⇒ clog(𝑖·z+csqrt((1-z)·(1+z)))/𝑖;
def ccos(z:!ℂ)lifted:!ℂ{
	(re,im):=ctori(z);
	return cfromri(cos(re)·cosh(im),-sin(re)·sinh(im));
}
def cacos(z:!ℂ)lifted:!ℂ ⇒ clog(z+𝑖·csqrt((1-z)·(1+z)))/𝑖;
//def ctan(z:!ℂ)lifted:!ℂ ⇒ csin(z)/ccos(z);
def ctan(z:!ℂ)lifted:!ℂ{
	(re,im):=ctori(z);
	num_re:=sin(2·re);
	num_im:=sinh(2·im);
	den:=cos(2·re)+cosh(2·im);
	return cfromri(num_re/den,num_im/den);
}
def catan(z:!ℂ)lifted:!ℂ ⇒ 𝑖/2·(clog1p(-𝑖·z)-clog1p(𝑖·z));

def csinh(z:!ℂ)lifted:!ℂ ⇒ (cexpm1(z)-cexpm1(-z))/2;
def casinh(z:!ℂ)lifted:!ℂ ⇒ clog1p(z+csqrt1pm1(z^2));
def ccosh(z:!ℂ)lifted:!ℂ ⇒ (cexpm1(z)+cexpm1(-z))/2;
def cacosh(z:!ℂ)lifted:!ℂ ⇒ clog1p((z-1)+csqrt(z-1)·csqrt(z+1));
//def ctanh(z:!ℂ)lifted:!ℂ ⇒ csinh(z)/ccosh(z);
def ctanh(z:!ℂ)lifted:!ℂ{
	(re,im):=ctori(z);
	num_re:=sinh(2·re);
	num_im:=sin(2·im);
	den:=cosh(2·re)+cos(2·im);
	return cfromri(num_re/den,num_im/den);
}
def catanh(z:!ℂ)lifted:!ℂ ⇒ (clog1p(z)-clog1p(-z))/2;

def array[τ:*](n: !ℕ,const x:τ) @[artificial] lifted: τ[]⇒vector[τ](n, x);
def vector[τ:*](n:!ℕ,const x:τ) @[artificial] lifted: τ^n {
	def impl[τ](n: !ℕ, const x: τ) @[extern="primitive.vector"] lifted: τ^n; // TODO: make unnecessary
	return impl[τ](n, x);
}

def print[τ:*](x:!τ) @[artificial] lifted: 𝟙 {
	def impl[τ': ctype](x: τ') @[extern="primitive.print"] lifted: 𝟙; // TODO: make unnecessary
	impl[!τ](x);
}
def dump() @[extern="primitive.dump"] lifted: 𝟙;
def exit() @[extern="primitive.exit"] lifted: ⊥;

